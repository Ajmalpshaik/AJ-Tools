<!--
Tool Name : C#
Purpose   : Dockable pane view for the AJ Tools interactive AI-assisted C# shell (prompt -> generated
            code -> review/run/save against the live Revit document). Soft Revit UI style (Neumorphism +
            Claymorphism, Neon Blue primary, dark theme).
Author    : Ajmal P.S.
Version   : 2.1.0
Last Updated : 2026-07-18
Changelog :
  v2.1.0 - Settings moved out of this pane's inline collapsible panel into its own popup
           (SettingsWindow.xaml, opened from code-behind) per Ajmal's request. Shared brush/style
           resources extracted to SoftUiStyles.xaml (merged dictionary) so the pane and the new
           popup stay visually consistent from one source instead of duplicated XAML.
  v2.0.0 - Restyled to the house Soft Revit UI look; no ViewModel/behaviour change.
-->
<UserControl x:Class="AJTools.AiShell.Views.AiShellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
             xmlns:localHelpers="clr-namespace:AJTools.AiShell.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="400"
             FontFamily="Segoe UI" FontSize="13">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="SoftUiStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <localHelpers:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
            <localHelpers:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>
    <!-- Outer layer paints the full pane edge-to-edge; a root element can't StaticResource its own
         Resources on its own attributes (WPF processes them before Resources is populated), so the
         background/foreground live one level down instead, on the first real child. -->
    <Grid Background="{StaticResource SurfaceBrush}" TextElement.Foreground="{StaticResource TextBrush}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Top Bar -->
            <RowDefinition Height="Auto"/> <!-- Settings Panel -->
            <RowDefinition Height="1.5*"/> <!-- Chat / Prompt -->
            <RowDefinition Height="Auto"/> <!-- Generate Button -->
            <RowDefinition Height="2.5*"/> <!-- Code Editor -->
            <RowDefinition Height="Auto"/> <!-- Run Buttons -->
            <RowDefinition Height="2*"/>   <!-- Results & Error -->
            <RowDefinition Height="Auto"/> <!-- Saved Scripts Expander -->
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="⚙ Settings" Click="SettingsButton_Click"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                    Style="{StaticResource SecondaryButtonStyle}" Padding="12,6"/>
            <TextBlock Text="{Binding ProviderStatusText}" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="{StaticResource PrimaryBrush}" FontSize="11"/>
            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Margin="14,0,0,0" Foreground="{StaticResource MutedBrush}"/>
            <ProgressBar IsIndeterminate="True" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                         Width="50" Height="4" Margin="12,0,0,0" Style="{StaticResource ProgressBarStyle}"/>
        </StackPanel>

        <!-- Prompt Input -->
        <Border Grid.Row="2" Style="{StaticResource SoftCardStyle}">
            <DockPanel>
                <TextBlock Text="Prompt" Style="{StaticResource SectionHeaderStyle}" DockPanel.Dock="Top"/>
                <TextBox Text="{Binding PromptInput, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource SoftTextBoxStyle}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
            </DockPanel>
        </Border>

        <!-- Generate - normal-sized (was a big full-width bar), Stop sits right beside it so there's
             a way to cancel while the AI is generating, not just while the code is running below. -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,10">
            <Button Content="Generate C# Code" Command="{Binding GenerateCodeCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                    Style="{StaticResource PrimaryButtonStyle}" Padding="14,8"/>
            <Button Content="⏹ Stop" Command="{Binding StopCommand}"
                    Style="{StaticResource WarningButtonStyle}" Padding="14,8" Margin="8,0,0,0"
                    Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </StackPanel>

        <!-- Code Editor -->
        <Border Grid.Row="4" Style="{StaticResource SoftCardStyle}">
            <DockPanel>
                <TextBlock Text="C# Code" Style="{StaticResource SectionHeaderStyle}" DockPanel.Dock="Top"/>
                <avalonEdit:TextEditor x:Name="CodeEditor"
                                       SyntaxHighlighting="C#"
                                       ShowLineNumbers="True"
                                       FontFamily="Consolas"
                                       FontSize="13"
                                       Background="{StaticResource SurfaceBrush}"
                                       Foreground="#DCDCDC"
                                       Padding="6"
                                       TextChanged="CodeEditor_TextChanged"/>
            </DockPanel>
        </Border>

        <!-- Execution Controls & Progress -->
        <StackPanel Grid.Row="5" Margin="0,10,0,10">
            <!-- Auto-sized (no fixed Width) so button text is never clipped, regardless of label
                 length - a fixed-width row previously cut off "Review Code"/"Format Code". -->
            <StackPanel Orientation="Horizontal">
                <Button Content="▶ Run Code" Command="{Binding RunCodeCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                        Style="{StaticResource PrimaryButtonStyle}" Padding="14,8"/>
                <Button Content="Review Code" Command="{Binding ReviewCodeCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                        Style="{StaticResource SecondaryButtonStyle}" Padding="14,8" Margin="8,0,0,0"/>
                <Button Content="Format Code" Command="{Binding FormatCodeCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                        Style="{StaticResource SecondaryButtonStyle}" Padding="14,8" Margin="8,0,0,0"/>
                <Button Content="Save Script" Command="{Binding SaveScriptCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                        Style="{StaticResource SecondaryButtonStyle}" Padding="14,8" Margin="8,0,0,0"/>
                <Button Content="⏹ Stop" Command="{Binding StopCommand}"
                        Style="{StaticResource WarningButtonStyle}" Padding="14,8" Margin="8,0,0,0"
                        Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </StackPanel>

            <Grid Margin="0,12,0,0" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ProgressBar Value="{Binding ExecutionProgress}" Minimum="0" Maximum="100" Height="22" Style="{StaticResource ProgressBarStyle}"/>
                <TextBlock Text="{Binding ExecutionProgressText}" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" FontSize="11"/>
            </Grid>
        </StackPanel>

        <!-- Execution Results -->
        <Border Grid.Row="6" Style="{StaticResource SoftCardStyle}">
            <DockPanel>
                <TextBlock Text="Output" Style="{StaticResource SectionHeaderStyle}" DockPanel.Dock="Top"/>
                <TextBox Text="{Binding ExecutionResults}" IsReadOnly="True" Style="{StaticResource SoftMonoTextBoxStyle}"
                         BorderThickness="0" Background="Transparent" MinHeight="90"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
            </DockPanel>
        </Border>

        <!-- Saved History Panel -->
        <Expander Grid.Row="7" Header="Saved Scripts History" Foreground="{StaticResource TextBrush}"
                  BorderBrush="{StaticResource BorderBrush}" Background="{StaticResource CardBrush}"
                  Margin="0,12,0,0" Padding="4" IsExpanded="False">
            <ListBox ItemsSource="{Binding SavedHistory}" Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled" MaxHeight="250" Margin="0,8,0,0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource SoftCardBrush}" CornerRadius="10" Margin="0,3" Padding="10"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"
                                           VerticalAlignment="Center" ToolTip="{Binding ToolTipText}"/>
                                <Button Grid.Column="1" Content="▶ Run"
                                        Command="{Binding DataContext.RunFromHistoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        IsEnabled="{Binding DataContext.IsBusy, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBooleanConverter}}"
                                        Style="{StaticResource PrimaryButtonStyle}" Margin="8,0,0,0" Padding="10,4" FontSize="11"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Expander>
    </Grid>
    </Grid>
</UserControl>
