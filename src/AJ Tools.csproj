      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
  <ItemGroup>
    <DeployRoots Include="$(RevitAddinAllUsersRoot)" />
  </ItemGroup>
  <Target Name="DeployRevitAddin" AfterTargets="Build" Condition=" '$(SkipRevitAddinDeploy)' != 'true' ">
    <ItemGroup>
      <DeployDirs Include="@(DeployRoots->'%(FullPath)$(RevitAddinDeployName)')" />
    </ItemGroup>
    <RemoveDir Directories="@(DeployDirs)" />
    <MakeDir Directories="@(DeployDirs);@(DeployDirs->'%(FullPath)Resources')" />
    <Copy SourceFiles="$(TargetPath)" DestinationFiles="@(DeployDirs->'%(FullPath)AJ Tools.dll')" OverwriteReadOnlyFiles="true" />
    <Copy Condition="Exists('$(TargetDir)AJ Tools.pdb')" SourceFiles="$(TargetDir)AJ Tools.pdb" DestinationFiles="@(DeployDirs->'%(FullPath)AJ Tools.pdb')" OverwriteReadOnlyFiles="true" />
    <Copy SourceFiles="@(Content)" DestinationFolder="%(DeployDirs.FullPath)Resources" SkipUnchangedFiles="true" OverwriteReadOnlyFiles="true" Condition="@(Content) != ''" />
    <PropertyGroup>
      <AddinTemplate><![CDATA[<?xml version="1.0" encoding="utf-8" standalone="no"?>
<RevitAddIns>
  <AddIn Type="Application">
    <Name>AJ Tools</Name>
    <AddInId>{C14A253D-96C6-42B7-889A-CFE737556BA9}</AddInId>
    <FullClassName>AJTools.App.App</FullClassName>
    <Assembly>%(DeployDirs.FullPath)AJ Tools.dll</Assembly>
    <VendorId>AJT</VendorId>
    <VendorDescription>Ajmal P.S - ajmalnattika@gmail.com</VendorDescription>
  </AddIn>
</RevitAddIns>]]></AddinTemplate>
    </PropertyGroup>
    <WriteLinesToFile File="%(DeployDirs.FullPath)AJ Tools.addin" Lines="$(AddinTemplate)" Overwrite="true" WriteOnlyWhenDifferent="true" Encoding="UTF-8" />
  </Target>
  <Import Project="$(MSBuildBinPath)\Microsoft.CSharp.targets" />

</Project>
