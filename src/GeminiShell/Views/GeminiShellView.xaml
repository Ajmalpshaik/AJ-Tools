<UserControl x:Class="AJTools.GeminiShell.Views.GeminiShellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
             xmlns:localHelpers="clr-namespace:AJTools.GeminiShell.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="400"
             Background="#1E1E1E" Foreground="White">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <localHelpers:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <localHelpers:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
    </UserControl.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Top Bar -->
            <RowDefinition Height="Auto"/> <!-- Settings Panel -->
            <RowDefinition Height="2*"/>   <!-- Chat / Prompt -->
            <RowDefinition Height="Auto"/> <!-- Generate Button -->
            <RowDefinition Height="3*"/>   <!-- Code Editor -->
            <RowDefinition Height="Auto"/> <!-- Run Buttons -->
            <RowDefinition Height="1.5*"/> <!-- Results & Error -->
            <RowDefinition Height="Auto"/> <!-- Saved Scripts Expander -->
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="⚙ Settings" Command="{Binding ToggleSettingsCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                    Padding="10,5" Background="#333" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <TextBlock Text="{Binding ProviderStatusText}" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="#8AB4F8" FontSize="11"/>
            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Margin="15,0,0,0" Foreground="#AAAAAA"/>
            <ProgressBar IsIndeterminate="True" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" Width="50" Height="5" Margin="10,0,0,0"/>
        </StackPanel>

        <!-- Settings Panel -->
        <Border Grid.Row="1" Background="#252526" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="3" Margin="0,0,0,10" 
                Visibility="{Binding IsSettingsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Margin="10">
                <TextBlock Text="AI Provider Configuration" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Provider:" Width="70" VerticalAlignment="Center" Foreground="#AAAAAA"/>
                    <ComboBox Width="150" SelectedValue="{Binding SelectedProvider}" SelectedValuePath="Content">
                        <ComboBoxItem Content="Gemini"/>
                        <ComboBoxItem Content="OpenAI"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Margin="0,0,0,10" Visibility="{Binding IsGeminiSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="Gemini API Key:" Foreground="#AAAAAA" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding GeminiApiKeyInput, UpdateSourceTrigger=PropertyChanged}" Background="#1E1E1E" Foreground="White" BorderBrush="#3E3E42" Padding="4"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,10" Visibility="{Binding IsOpenAiSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="OpenAI API Key:" Foreground="#AAAAAA" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding OpenAiApiKeyInput, UpdateSourceTrigger=PropertyChanged}" Background="#1E1E1E" Foreground="White" BorderBrush="#3E3E42" Padding="4"/>
                    
                    <TextBlock Text="OpenAI Model (Select for cost/token control):" Foreground="#AAAAAA" Margin="0,10,0,5"/>
                    <ComboBox SelectedValue="{Binding OpenAiModel}" SelectedValuePath="Content" Width="150" HorizontalAlignment="Left">
                        <ComboBoxItem Content="gpt-5.5-mini"/>
                        <ComboBoxItem Content="gpt-4o-mini"/>
                        <ComboBoxItem Content="gpt-4o"/>
                        <ComboBoxItem Content="gpt-4-turbo"/>
                        <ComboBoxItem Content="gpt-3.5-turbo"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Local Scripts Folder:" Foreground="#AAAAAA" Margin="0,0,0,5"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding ScriptsFolderPath, UpdateSourceTrigger=PropertyChanged}" Background="#1E1E1E" Foreground="White" BorderBrush="#3E3E42" Padding="4" IsReadOnly="True"/>
                        <Button Grid.Column="1" Content="Browse..." Command="{Binding BrowseFolderCommand}" Margin="5,0,0,0" Padding="10,0" Background="#333" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    </Grid>
                </StackPanel>

                <Button Content="Save Settings" Command="{Binding SaveSettingsCommand}" 
                        HorizontalAlignment="Left" Padding="15,5" Background="#007ACC" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- Prompt Input -->
        <GroupBox Grid.Row="2" Header="Prompt" Foreground="White" BorderBrush="#333">
            <TextBox Text="{Binding PromptInput, UpdateSourceTrigger=PropertyChanged}" 
                     AcceptsReturn="True" TextWrapping="Wrap" Background="#2D2D2D" Foreground="White" BorderThickness="0" Padding="5"/>
        </GroupBox>

        <!-- Generate -->
        <Button Grid.Row="3" Content="Generate C# Code" Command="{Binding GenerateCodeCommand}"
                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                Margin="0,5,0,5" Padding="0,8" Background="#0F9D58" Foreground="White" BorderThickness="0" FontWeight="Bold" Cursor="Hand"/>

        <!-- Code Editor -->
        <GroupBox Grid.Row="4" Header="C# Code Editor" Foreground="White" BorderBrush="#333">
            <avalonEdit:TextEditor x:Name="CodeEditor" 
                                   SyntaxHighlighting="C#" 
                                   ShowLineNumbers="True" 
                                   FontFamily="Consolas" 
                                   FontSize="13" 
                                   Background="#1E1E1E" 
                                   Foreground="#DCDCDC" 
                                   TextChanged="CodeEditor_TextChanged"/>
        </GroupBox>

        <!-- Execution Controls & Progress -->
        <StackPanel Grid.Row="5" Margin="0,5,0,5">
            <StackPanel Orientation="Horizontal">
                <Button Content="▶ Run Code" Command="{Binding RunCodeCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                        Width="100" Padding="0,5" Background="#DB4437" Foreground="White" BorderThickness="0" FontWeight="Bold" Cursor="Hand"/>
                <Button Content="Review Code" Command="{Binding ReviewCodeCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                        Width="100" Padding="0,5" Margin="10,0,0,0" Background="#333" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button Content="🧹 Format Code" Command="{Binding FormatCodeCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                        Width="100" Padding="0,5" Margin="10,0,0,0" Background="#9B59B6" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button Content="💾 Save Script" Command="{Binding SaveScriptCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                        Width="100" Padding="0,5" Margin="10,0,0,0" Background="#007ACC" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button Content="⏹ Stop" Command="{Binding StopCommand}"
                        Width="80" Padding="0,5" Margin="10,0,0,0" Background="#F4B400" Foreground="Black" BorderThickness="0" FontWeight="Bold" Cursor="Hand"
                        Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </StackPanel>
            
            <Grid Margin="0,10,0,0" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ProgressBar Value="{Binding ExecutionProgress}" Minimum="0" Maximum="100" Height="20" Background="#2D2D2D" Foreground="#007ACC" BorderThickness="0"/>
                <TextBlock Text="{Binding ExecutionProgressText}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold" FontSize="11"/>
            </Grid>
        </StackPanel>

        <!-- Execution Results -->
        <GroupBox Grid.Row="6" Header="Output Console" Foreground="White" BorderBrush="#333">
            <TextBox Text="{Binding ExecutionResults}" IsReadOnly="True" 
                     AcceptsReturn="True" TextWrapping="Wrap" Background="#2D2D2D" Foreground="#A9B7C6" BorderThickness="0" Padding="5" FontFamily="Consolas"/>
        </GroupBox>

        <!-- Saved History Panel -->
        <Expander Grid.Row="7" Header="Saved Scripts History" Foreground="White" BorderBrush="#333" Margin="0,10,0,0" Background="#252526" IsExpanded="False">
            <ListBox ItemsSource="{Binding SavedHistory}" Background="#1E1E1E" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" MaxHeight="250">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#2D2D2D" CornerRadius="3" Margin="0,2" Padding="8" BorderBrush="#3E3E42" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding DisplayName}" Foreground="#DCDCDC" TextWrapping="Wrap" VerticalAlignment="Center" ToolTip="{Binding ToolTipText}"/>
                                <Button Grid.Column="1" Content="▶ Run"
                                        Command="{Binding DataContext.RunFromHistoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        IsEnabled="{Binding DataContext.IsBusy, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBooleanConverter}}"
                                        Margin="5,0,0,0" Padding="5,2" Background="#0F9D58" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Expander>
    </Grid>
</UserControl>
