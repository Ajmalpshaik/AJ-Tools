<Window x:Class="AJTools.UI.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About AJ Tools"
        Width="980"
        Height="580"
        MinWidth="860"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <SolidColorBrush x:Key="WindowBgBrush" Color="#0B0F16"/>
        <SolidColorBrush x:Key="SidebarBgBrush" Color="#111722"/>
        <SolidColorBrush x:Key="CardBgBrush" Color="#1B2332"/>
        <SolidColorBrush x:Key="BorderBrushDark" Color="#2A3446"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#AAB4C5"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#7F8BA3"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#00E5FF"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#22C55E"/>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="14,0,14,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1D2635"/>
                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="BodyTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="21"/>
        </Style>

        <Style x:Key="ValueLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="ValueTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="LinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                    <Setter Property="Background" Value="#162030"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource WindowBgBrush}"
            BorderBrush="#202838"
            BorderThickness="1"
            CornerRadius="22"
            SnapsToDevicePixels="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource SidebarBgBrush}"
                    BorderBrush="{StaticResource BorderBrushDark}"
                    BorderThickness="0,0,1,0"
                    CornerRadius="22,0,0,22">
                <Grid Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,8,0,18">
                        <Border Width="56"
                                Height="56"
                                Background="White"
                                CornerRadius="16"
                                HorizontalAlignment="Left">
                            <TextBlock Text="AJ"
                                       Foreground="Black"
                                       FontWeight="Black"
                                       FontSize="22"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="AJ TOOLS"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Margin="0,16,0,2"/>

                        <TextBlock Text="Revit Productivity Suite"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1">
                        <Button x:Name="BtnGeneral" Tag="general" Click="NavButton_Click" Style="{StaticResource NavButtonStyle}" Content="System Info"/>
                        <Button x:Name="BtnDeveloper" Tag="developer" Click="NavButton_Click" Style="{StaticResource NavButtonStyle}" Content="Developer"/>
                        <Button x:Name="BtnTools" Tag="tools" Click="NavButton_Click" Style="{StaticResource NavButtonStyle}" Content="Core Tools"/>
                        <Button x:Name="BtnUpdates" Tag="updates" Click="NavButton_Click" Style="{StaticResource NavButtonStyle}" Content="Updates"/>
                        <Button x:Name="BtnLicense" Tag="license" Click="NavButton_Click" Style="{StaticResource NavButtonStyle}" Content="License"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0,12,0,0">
                        <Button Style="{StaticResource LinkButtonStyle}" Click="GitHubButton_Click" Content="GitHub Repository"/>
                        <Button Style="{StaticResource LinkButtonStyle}" Click="SupportButton_Click" Content="Support / Email" Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="54"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="44"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#0F1520"
                        BorderBrush="{StaticResource BorderBrushDark}"
                        BorderThickness="0,0,0,1"
                        MouseLeftButtonDown="Header_MouseLeftButtonDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="About AJ Tools"
                                   VerticalAlignment="Center"
                                   Margin="24,0,0,0"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>

                        <Button Grid.Column="1"
                                Width="34"
                                Height="34"
                                Margin="0,10,12,10"
                                Click="CloseButton_Click"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                FontSize="14"
                                FontWeight="Bold"
                                Cursor="Hand"
                                Content="X"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <Grid Margin="28">
                        <StackPanel x:Name="GeneralPanel">
                            <Border Background="#162030"
                                    BorderBrush="#21445A"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="10,6"
                                    HorizontalAlignment="Left"
                                    Margin="0,0,0,14">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="System Operational"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="11"
                                               FontWeight="Bold"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="AJ Tools Platform" Style="{StaticResource SectionTitleStyle}"/>

                            <TextBlock Style="{StaticResource BodyTextStyle}"
                                       Text="AJ Tools is a Revit productivity add-in focused on practical BIM workflows, clean model coordination, automation, and day-to-day drafting speed. This About window keeps your tool details, supported platform, developer info, update notes, and repository access in one place."
                                       Margin="0,0,0,18"/>

                            <UniformGrid Columns="2" Margin="0,0,0,6">
                                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,10,14">
                                    <StackPanel>
                                        <TextBlock Text="Current Version" Style="{StaticResource ValueLabelStyle}"/>
                                        <TextBlock x:Name="VersionText" Style="{StaticResource ValueTextStyle}" Text="v1.0.0"/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardBorderStyle}" Margin="10,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="Revit Target" Style="{StaticResource ValueLabelStyle}"/>
                                        <TextBlock x:Name="RevitVersionText" Style="{StaticResource ValueTextStyle}" Text="Revit 2020"/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,10,14">
                                    <StackPanel>
                                        <TextBlock Text=".NET Framework" Style="{StaticResource ValueLabelStyle}"/>
                                        <TextBlock x:Name="FrameworkText" Style="{StaticResource ValueTextStyle}" Text="4.7.2"/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardBorderStyle}" Margin="10,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="Deployment" Style="{StaticResource ValueLabelStyle}"/>
                                        <TextBlock x:Name="DeploymentText" Style="{StaticResource ValueTextStyle}" Text="GitHub Release / Add-in Package"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>

                        <StackPanel x:Name="DeveloperPanel" Visibility="Collapsed">
                            <TextBlock Text="Developer" Style="{StaticResource SectionTitleStyle}"/>

                            <Border Style="{StaticResource CardBorderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Width="72"
                                            Height="72"
                                            CornerRadius="18"
                                            Background="#111722"
                                            BorderBrush="{StaticResource BorderBrushDark}"
                                            BorderThickness="1"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top">
                                        <TextBlock Text="AJ"
                                                   Foreground="White"
                                                   FontSize="26"
                                                   FontWeight="Bold"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="18,0,0,0">
                                        <TextBlock Text="Ajmal P.S."
                                                   Foreground="White"
                                                   FontSize="20"
                                                   FontWeight="Bold"/>
                                        <TextBlock Text="BIM Modeller / Revit Add-in Developer"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="13"
                                                   Margin="0,4,0,10"/>

                                        <TextBlock Style="{StaticResource BodyTextStyle}"
                                                   Text="Focused on Revit productivity, BIM model quality, MEP workflows, and practical tools that solve real project work. This About tool is designed to keep the same premium UI feeling while showing proper AJ Tools information."/>

                                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                            <Button Style="{StaticResource LinkButtonStyle}" Click="GitHubButton_Click" Content="Open GitHub"/>
                                            <Button Style="{StaticResource LinkButtonStyle}" Click="LinkedInButton_Click" Content="LinkedIn"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <StackPanel x:Name="ToolsPanel" Visibility="Collapsed">
                            <TextBlock Text="Core Tools" Style="{StaticResource SectionTitleStyle}"/>

                            <Border Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Foreground="White" FontSize="15" FontWeight="SemiBold" Text="Main AJ Tools Modules" Margin="0,0,0,10"/>
                                    <TextBlock Style="{StaticResource BodyTextStyle}" Text="- Auto Dimensions&#x0a;- Copy View Range&#x0a;- Filter Pro&#x0a;- Linked ID Viewer / Linked Element Search&#x0a;- Reset Datums&#x0a;- Reset Overrides&#x0a;- Reset Text Position&#x0a;- Unhide All&#x0a;- About / Help utilities"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Foreground="White" FontSize="15" FontWeight="SemiBold" Text="Purpose" Margin="0,0,0,10"/>
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Text="Built for faster BIM production, cleaner model management, repeatable standards, and easier everyday Revit work without unnecessary clicks."/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel x:Name="UpdatesPanel" Visibility="Collapsed">
                            <TextBlock Text="Updates" Style="{StaticResource SectionTitleStyle}"/>

                            <Border Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Foreground="White" FontSize="15" FontWeight="SemiBold" Text="Current Direction" Margin="0,0,0,10"/>
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Text="- Cleaner ribbon structure&#x0a;- Better UI consistency across tools&#x0a;- Improved Revit 2020 compatibility focus&#x0a;- Easier packaging and GitHub release workflow"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Foreground="White" FontSize="15" FontWeight="SemiBold" Text="Note" Margin="0,0,0,10"/>
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Text="Replace these update notes any time with your exact release notes. The layout is already ready."/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel x:Name="LicensePanel" Visibility="Collapsed">
                            <TextBlock Text="License" Style="{StaticResource SectionTitleStyle}"/>

                            <Border Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Foreground="White" FontSize="15" FontWeight="SemiBold" Text="Usage" Margin="0,0,0,10"/>
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Text="AJ Tools is intended for professional BIM and Revit workflow use. Unauthorized redistribution, repackaging, or misuse of the add-in package should be restricted based on your release policy."/>

                                    <Border Background="#121826"
                                            BorderBrush="{StaticResource BorderBrushDark}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="10"
                                            Margin="0,16,0,0">
                                        <TextBlock x:Name="LicenseKeyText"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontFamily="Consolas"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Text="AJ-TOOLS-REVIT-2020"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Background="#0F1520"
                        BorderBrush="{StaticResource BorderBrushDark}"
                        BorderThickness="0,1,0,0">
                    <Grid Margin="18,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="CopyrightText"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Text="(c) 2026 AJ Tools"/>

                        <TextBlock Grid.Column="1"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Text="Revit Productivity Suite"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
