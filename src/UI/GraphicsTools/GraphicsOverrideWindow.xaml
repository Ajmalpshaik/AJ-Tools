<Window x:Class="AJTools.UI.GraphicsTools.GraphicsOverrideWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Graphics Override Settings"
        Width="560"
        Height="620"
        MinWidth="520"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundDark}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../ModernStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
                <Setter Property="Background" Value="#FF3A3A3A"/>
                <Setter Property="Foreground" Value="#FFFFFFFF"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="#FF646464"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#FF4A4A4A"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#FF2E2E2E"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource CardBackground}"
                CornerRadius="8"
                Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Graphics Override Settings"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}"/>

                <Grid Grid.Row="1" Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="QuickColorTargetLabel"
                               Grid.Column="0"
                               Text="Apply Preset To"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondary}"/>

                    <ComboBox x:Name="QuickColorTargetCombo"
                              Grid.Column="1"
                              Height="24"
                              Background="{StaticResource BackgroundLight}"
                              Foreground="{StaticResource TextPrimary}"
                              BorderBrush="#FF555555"
                              SelectedIndex="0">
                        <ComboBoxItem Content="Projection Line Color" Tag="ProjectionLineColor"/>
                        <ComboBoxItem Content="Surface Foreground Color" Tag="SurfaceForegroundColor"/>
                        <ComboBoxItem Content="Surface Background Color" Tag="SurfaceBackgroundColor"/>
                        <ComboBoxItem Content="Cut Line Color" Tag="CutLineColor"/>
                        <ComboBoxItem Content="Cut Foreground Color" Tag="CutForegroundColor"/>
                        <ComboBoxItem Content="Cut Background Color" Tag="CutBackgroundColor"/>
                    </ComboBox>

                    <TextBlock x:Name="QuickColorAllNoticeText"
                               Grid.Column="1"
                               Text="Preset applies to all Projection/Surface/Cut colors."
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondary}"
                               Visibility="Collapsed"/>
                </Grid>

                <WrapPanel Grid.Row="2" Margin="0,6,0,6">
                    <Button Width="22" Height="20" Margin="0,0,4,0" ToolTip="Black" Tag="0,0,0" Click="OnQuickColorPreset" Background="#FF000000" BorderBrush="#FF707070" BorderThickness="1"/>
                    <Button Width="22" Height="20" Margin="0,0,4,0" ToolTip="White" Tag="255,255,255" Click="OnQuickColorPreset" Background="#FFFFFFFF" BorderBrush="#FF707070" BorderThickness="1"/>
                    <Button Width="22" Height="20" Margin="0,0,4,0" ToolTip="Red" Tag="255,0,0" Click="OnQuickColorPreset" Background="#FFFF0000" BorderBrush="#FF707070" BorderThickness="1"/>
                    <Button Width="22" Height="20" Margin="0,0,4,0" ToolTip="Green" Tag="0,255,0" Click="OnQuickColorPreset" Background="#FF00FF00" BorderBrush="#FF707070" BorderThickness="1"/>
                    <Button Width="22" Height="20" Margin="0,0,4,0" ToolTip="Blue" Tag="0,0,255" Click="OnQuickColorPreset" Background="#FF0000FF" BorderBrush="#FF707070" BorderThickness="1"/>
                    <Button Width="22" Height="20" Margin="0,0,4,0" ToolTip="Cyan" Tag="0,255,255" Click="OnQuickColorPreset" Background="#FF00FFFF" BorderBrush="#FF707070" BorderThickness="1"/>
                    <Button Width="22" Height="20" Margin="0,0,4,0" ToolTip="Magenta" Tag="255,0,255" Click="OnQuickColorPreset" Background="#FFFF00FF" BorderBrush="#FF707070" BorderThickness="1"/>
                    <Button Width="22" Height="20" Margin="0,0,4,0" ToolTip="Yellow" Tag="255,255,0" Click="OnQuickColorPreset" Background="#FFFFFF00" BorderBrush="#FF707070" BorderThickness="1"/>
                    <Button Width="22" Height="20" Margin="0,0,4,0" ToolTip="Orange" Tag="255,165,0" Click="OnQuickColorPreset" Background="#FFFFA500" BorderBrush="#FF707070" BorderThickness="1"/>
                    <Button Width="22" Height="20" Margin="0,0,8,0" ToolTip="Gray" Tag="128,128,128" Click="OnQuickColorPreset" Background="#FF808080" BorderBrush="#FF707070" BorderThickness="1"/>
                    <Button Height="20" MinWidth="66" Content="By View" Tag="ByView" Click="OnQuickColorPreset" Style="{StaticResource SecondaryButton}" Padding="6,0"/>
                </WrapPanel>

                <TabControl Grid.Row="3" Margin="0,2,0,0">
                    <TabItem Header="Projection / Surface">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="8">
                                <TextBlock Text="Lines" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>

                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="185"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="56"/>
                                        <ColumnDefinition Width="56"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Projection Line Color" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                    <Border x:Name="ProjectionLineColorPreview" Grid.Column="1" Height="22" CornerRadius="3" BorderBrush="#FF707070" BorderThickness="1" Background="#FF3F3F46" Margin="0,0,6,0">
                                        <TextBlock x:Name="ProjectionLineColorText" Text="By View" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                                    </Border>
                                    <Button Grid.Column="2" Content="Pick" Tag="ProjectionLineColor" Style="{StaticResource ModernButton}" Height="22" Margin="0,0,4,0" Padding="6,0" Click="OnPickColor"/>
                                    <Button Grid.Column="3" Content="By" Tag="ProjectionLineColor" Style="{StaticResource SecondaryButton}" Height="22" Padding="6,0" Click="OnClearColor"/>
                                </Grid>

                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="185"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Projection Line Pattern" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                    <ComboBox x:Name="ProjectionLinePatternCombo" Grid.Column="1" Height="24" Background="{StaticResource BackgroundLight}" Foreground="{StaticResource TextPrimary}" BorderBrush="#FF555555"/>
                                </Grid>

                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="185"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Projection Line Weight" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                    <ComboBox x:Name="ProjectionLineWeightCombo" Grid.Column="1" Height="24" Background="{StaticResource BackgroundLight}" Foreground="{StaticResource TextPrimary}" BorderBrush="#FF555555"/>
                                </Grid>

                                <Separator Margin="0,8,0,8"/>
                                <TextBlock Text="Patterns" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>

                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="185"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Surface Foreground Pattern" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                    <ComboBox x:Name="SurfaceForegroundPatternCombo" Grid.Column="1" Height="24" Background="{StaticResource BackgroundLight}" Foreground="{StaticResource TextPrimary}" BorderBrush="#FF555555"/>
                                </Grid>

                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="185"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="56"/>
                                        <ColumnDefinition Width="56"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Surface Foreground Color" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                    <Border x:Name="SurfaceForegroundColorPreview" Grid.Column="1" Height="22" CornerRadius="3" BorderBrush="#FF707070" BorderThickness="1" Background="#FF3F3F46" Margin="0,0,6,0">
                                        <TextBlock x:Name="SurfaceForegroundColorText" Text="By View" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                                    </Border>
                                    <Button Grid.Column="2" Content="Pick" Tag="SurfaceForegroundColor" Style="{StaticResource ModernButton}" Height="22" Margin="0,0,4,0" Padding="6,0" Click="OnPickColor"/>
                                    <Button Grid.Column="3" Content="By" Tag="SurfaceForegroundColor" Style="{StaticResource SecondaryButton}" Height="22" Padding="6,0" Click="OnClearColor"/>
                                </Grid>

                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="185"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Surface Background Pattern" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                    <ComboBox x:Name="SurfaceBackgroundPatternCombo" Grid.Column="1" Height="24" Background="{StaticResource BackgroundLight}" Foreground="{StaticResource TextPrimary}" BorderBrush="#FF555555"/>
                                </Grid>

                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="185"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="56"/>
                                        <ColumnDefinition Width="56"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Surface Background Color" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                    <Border x:Name="SurfaceBackgroundColorPreview" Grid.Column="1" Height="22" CornerRadius="3" BorderBrush="#FF707070" BorderThickness="1" Background="#FF3F3F46" Margin="0,0,6,0">
                                        <TextBlock x:Name="SurfaceBackgroundColorText" Text="By View" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                                    </Border>
                                    <Button Grid.Column="2" Content="Pick" Tag="SurfaceBackgroundColor" Style="{StaticResource ModernButton}" Height="22" Margin="0,0,4,0" Padding="6,0" Click="OnPickColor"/>
                                    <Button Grid.Column="3" Content="By" Tag="SurfaceBackgroundColor" Style="{StaticResource SecondaryButton}" Height="22" Padding="6,0" Click="OnClearColor"/>
                                </Grid>

                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="185"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Transparency (0-100)" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                    <ComboBox x:Name="TransparencyCombo" Grid.Column="1" Height="24" Background="{StaticResource BackgroundLight}" Foreground="{StaticResource TextPrimary}" BorderBrush="#FF555555"/>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Cut">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="8">
                                <CheckBox x:Name="UseProjectionSurfaceColorsForCutCheckBox"
                                          Content="Use Projection/Surface Colors For Cut"
                                          Style="{StaticResource ModernCheckBox}"
                                          Margin="0,0,0,4"
                                          Checked="OnUseProjectionSurfaceColorsForCutChanged"
                                          Unchecked="OnUseProjectionSurfaceColorsForCutChanged"/>

                                <TextBlock Text="Lines" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>

                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="185"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="56"/>
                                        <ColumnDefinition Width="56"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Cut Line Color" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                    <Border x:Name="CutLineColorPreview" Grid.Column="1" Height="22" CornerRadius="3" BorderBrush="#FF707070" BorderThickness="1" Background="#FF3F3F46" Margin="0,0,6,0">
                                        <TextBlock x:Name="CutLineColorText" Text="By View" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                                    </Border>
                                    <Button x:Name="CutLineColorPickButton" Grid.Column="2" Content="Pick" Tag="CutLineColor" Style="{StaticResource ModernButton}" Height="22" Margin="0,0,4,0" Padding="6,0" Click="OnPickColor"/>
                                    <Button x:Name="CutLineColorClearButton" Grid.Column="3" Content="By" Tag="CutLineColor" Style="{StaticResource SecondaryButton}" Height="22" Padding="6,0" Click="OnClearColor"/>
                                </Grid>

                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="185"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Cut Line Pattern" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                    <ComboBox x:Name="CutLinePatternCombo" Grid.Column="1" Height="24" Background="{StaticResource BackgroundLight}" Foreground="{StaticResource TextPrimary}" BorderBrush="#FF555555"/>
                                </Grid>

                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="185"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Cut Line Weight" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                    <ComboBox x:Name="CutLineWeightCombo" Grid.Column="1" Height="24" Background="{StaticResource BackgroundLight}" Foreground="{StaticResource TextPrimary}" BorderBrush="#FF555555"/>
                                </Grid>

                                <Separator Margin="0,8,0,8"/>
                                <TextBlock Text="Patterns" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>

                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="185"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Cut Foreground Pattern" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                    <ComboBox x:Name="CutForegroundPatternCombo" Grid.Column="1" Height="24" Background="{StaticResource BackgroundLight}" Foreground="{StaticResource TextPrimary}" BorderBrush="#FF555555"/>
                                </Grid>

                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="185"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="56"/>
                                        <ColumnDefinition Width="56"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Cut Foreground Color" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                    <Border x:Name="CutForegroundColorPreview" Grid.Column="1" Height="22" CornerRadius="3" BorderBrush="#FF707070" BorderThickness="1" Background="#FF3F3F46" Margin="0,0,6,0">
                                        <TextBlock x:Name="CutForegroundColorText" Text="By View" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                                    </Border>
                                    <Button x:Name="CutForegroundColorPickButton" Grid.Column="2" Content="Pick" Tag="CutForegroundColor" Style="{StaticResource ModernButton}" Height="22" Margin="0,0,4,0" Padding="6,0" Click="OnPickColor"/>
                                    <Button x:Name="CutForegroundColorClearButton" Grid.Column="3" Content="By" Tag="CutForegroundColor" Style="{StaticResource SecondaryButton}" Height="22" Padding="6,0" Click="OnClearColor"/>
                                </Grid>

                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="185"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Cut Background Pattern" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                    <ComboBox x:Name="CutBackgroundPatternCombo" Grid.Column="1" Height="24" Background="{StaticResource BackgroundLight}" Foreground="{StaticResource TextPrimary}" BorderBrush="#FF555555"/>
                                </Grid>

                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="185"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="56"/>
                                        <ColumnDefinition Width="56"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Cut Background Color" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                    <Border x:Name="CutBackgroundColorPreview" Grid.Column="1" Height="22" CornerRadius="3" BorderBrush="#FF707070" BorderThickness="1" Background="#FF3F3F46" Margin="0,0,6,0">
                                        <TextBlock x:Name="CutBackgroundColorText" Text="By View" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                                    </Border>
                                    <Button x:Name="CutBackgroundColorPickButton" Grid.Column="2" Content="Pick" Tag="CutBackgroundColor" Style="{StaticResource ModernButton}" Height="22" Margin="0,0,4,0" Padding="6,0" Click="OnPickColor"/>
                                    <Button x:Name="CutBackgroundColorClearButton" Grid.Column="3" Content="By" Tag="CutBackgroundColor" Style="{StaticResource SecondaryButton}" Height="22" Padding="6,0" Click="OnClearColor"/>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>

                <CheckBox x:Name="HalftoneCheckBox"
                           Grid.Row="4"
                          Content="Enable Halftone"
                          Style="{StaticResource ToggleSwitchCheckBox}"
                          Margin="0,6,0,0"/>

                <TextBlock x:Name="ErrorText"
                           Grid.Row="5"
                           Foreground="Crimson"
                           Margin="0,6,0,0"
                           TextWrapping="Wrap"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1"
                    Content="Reset"
                    Style="{StaticResource SecondaryButton}"
                    Height="30"
                    MinWidth="92"
                    FontSize="13"
                    Margin="0,0,6,0"
                    Click="OnReset"/>
            <Button Grid.Column="2"
                    Content="OK"
                    Style="{StaticResource ModernButton}"
                    Height="30"
                    MinWidth="92"
                    FontSize="13"
                    Margin="0,0,6,0"
                    Click="OnOk"/>
            <Button Grid.Column="3"
                    Content="Cancel"
                    Style="{StaticResource SecondaryButton}"
                    Height="30"
                    MinWidth="92"
                    FontSize="13"
                    Click="OnCancel"/>
        </Grid>
    </Grid>
</Window>
