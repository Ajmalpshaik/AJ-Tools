<Window x:Class="AJTools.UI.GraphicsTools.GraphicsOverrideWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Apply Graphics Settings"
        Width="660"
        Height="760"
        MinWidth="620"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundDark}"
        Foreground="{DynamicResource TextPrimary}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../ModernStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="ColorSwatchButton" TargetType="Button">
                <Setter Property="Width" Value="18"/>
                <Setter Property="Height" Value="18"/>
                <Setter Property="Margin" Value="0,0,4,0"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderSoft}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="SwatchRoot"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3"/>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="SwatchRoot" Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="SwatchRoot" Property="Opacity" Value="0.82"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource PanelCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Apply Graphics"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}"/>

                <StackPanel Grid.Row="1" Margin="0,8,0,0">
                    <TextBlock Text="Apply Mode"
                               Foreground="{StaticResource TextSecondary}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <RadioButton x:Name="ApplyModeElementsRadioButton"
                                     Content="Apply as Element Graphics"
                                     GroupName="ApplyMode"
                                     Margin="0,0,20,0"
                                     Foreground="{StaticResource TextPrimary}"
                                     Checked="OnApplyModeChanged"/>
                        <RadioButton x:Name="ApplyModeCategoriesRadioButton"
                                     Content="Apply as Category Graphics"
                                     GroupName="ApplyMode"
                                     Foreground="{StaticResource TextPrimary}"
                                     Checked="OnApplyModeChanged"/>
                    </StackPanel>
                    <TextBlock x:Name="ElementModeHintText"
                               Margin="0,4,0,0"
                               Foreground="{StaticResource TextSecondary}"
                               Text="Applies overrides to the selected elements only."
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Border x:Name="CategorySelectionPanel"
                        Grid.Row="2"
                        Margin="0,10,0,0"
                        Padding="10"
                        CornerRadius="6"
                        BorderBrush="{StaticResource BorderSoft}"
                        BorderThickness="1"
                        Background="{StaticResource CardBackground}"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Categories"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <Button Grid.Column="1"
                                    Content="Select All"
                                    MinWidth="90"
                                    Margin="0,0,6,0"
                                    Style="{StaticResource CompactSecondaryButton}"
                                    Click="OnSelectAllCategories"/>
                            <Button Grid.Column="2"
                                    Content="Clear"
                                    MinWidth="90"
                                    Style="{StaticResource CompactSecondaryButton}"
                                    Click="OnClearCategories"/>
                        </Grid>
                        <TextBlock x:Name="CategoryModeHintText"
                                   Grid.Row="1"
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource TextSecondary}"
                                   Text="Choose categories from the selected elements only, then apply active-view category overrides."
                                   TextWrapping="Wrap"/>
                        <ListBox x:Name="CategoryListBox"
                                 Grid.Row="2"
                                 Margin="0,8,0,0"
                                 Height="140"
                                 BorderThickness="1"
                                 BorderBrush="{StaticResource BorderSoft}"
                                 Background="{StaticResource BackgroundDark}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding DisplayName}"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              Style="{StaticResource ModernCheckBox}"
                                              Margin="0,1,0,1"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <TabControl Grid.Row="3" Margin="0,10,0,0">
                    <TabItem Header="Projection / Surface">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="8">
                                <TextBlock Text="Lines" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>

                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="185"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="56"/>
                                        <ColumnDefinition Width="56"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Projection Line Color" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                    <Border x:Name="ProjectionLineColorPreview" Grid.Column="1" Height="22" CornerRadius="3" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" Background="{StaticResource CardBackground}" Margin="0,0,6,0">
                                        <TextBlock x:Name="ProjectionLineColorText" Text="By View" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                                    </Border>
                                    <Button Grid.Column="2" Content="Pick" Tag="ProjectionLineColor" Style="{StaticResource CompactPrimaryButton}" Margin="0,0,4,0" Click="OnPickColor"/>
                                    <Button Grid.Column="3" Content="By" Tag="ProjectionLineColor" Style="{StaticResource CompactSecondaryButton}" Click="OnClearColor"/>
                                </Grid>
                                <WrapPanel Margin="185,4,0,0">
                                    <Button Style="{StaticResource ColorSwatchButton}" ToolTip="Black" Tag="ProjectionLineColor|0,0,0" Click="OnColorPreset" Background="#FF000000"/>
                                    <Button Style="{StaticResource ColorSwatchButton}" ToolTip="Red" Tag="ProjectionLineColor|255,0,0" Click="OnColorPreset" Background="#FFFF0000"/>
                                    <Button Style="{StaticResource ColorSwatchButton}" ToolTip="Green" Tag="ProjectionLineColor|0,255,0" Click="OnColorPreset" Background="#FF00FF00"/>
                                    <Button Style="{StaticResource ColorSwatchButton}" ToolTip="Blue" Tag="ProjectionLineColor|0,0,255" Click="OnColorPreset" Background="#FF0000FF"/>
                                    <Button Style="{StaticResource ColorSwatchButton}" ToolTip="Yellow" Tag="ProjectionLineColor|255,255,0" Click="OnColorPreset" Background="#FFFFFF00"/>
                                    <Button Style="{StaticResource ColorSwatchButton}" ToolTip="Gray" Tag="ProjectionLineColor|128,128,128" Click="OnColorPreset" Background="#FF808080"/>
                                    <Button MinWidth="64" Height="22" Content="By View" Tag="ProjectionLineColor|ByView" Click="OnColorPreset" Style="{StaticResource CompactSecondaryButton}"/>
                                </WrapPanel>

                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="185"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Projection Line Pattern" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                    <ComboBox x:Name="ProjectionLinePatternCombo" Grid.Column="1" Height="24" SelectionChanged="OnProjectionSurfaceSettingChanged"/>
                                </Grid>

                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="185"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Projection Line Weight" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                    <ComboBox x:Name="ProjectionLineWeightCombo" Grid.Column="1" Height="24" SelectionChanged="OnProjectionSurfaceSettingChanged"/>
                                </Grid>

                                <Separator Margin="0,8,0,8"/>
                                <TextBlock Text="Patterns" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>

                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="185"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Surface Foreground Pattern" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                    <ComboBox x:Name="SurfaceForegroundPatternCombo" Grid.Column="1" Height="24" SelectionChanged="OnProjectionSurfaceSettingChanged"/>
                                </Grid>

                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="185"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="56"/>
                                        <ColumnDefinition Width="56"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Surface Foreground Color" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                    <Border x:Name="SurfaceForegroundColorPreview" Grid.Column="1" Height="22" CornerRadius="3" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" Background="{StaticResource CardBackground}" Margin="0,0,6,0">
                                        <TextBlock x:Name="SurfaceForegroundColorText" Text="By View" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                                    </Border>
                                    <Button Grid.Column="2" Content="Pick" Tag="SurfaceForegroundColor" Style="{StaticResource CompactPrimaryButton}" Margin="0,0,4,0" Click="OnPickColor"/>
                                    <Button Grid.Column="3" Content="By" Tag="SurfaceForegroundColor" Style="{StaticResource CompactSecondaryButton}" Click="OnClearColor"/>
                                </Grid>
                                <WrapPanel Margin="185,4,0,0">
                                    <Button Style="{StaticResource ColorSwatchButton}" ToolTip="Black" Tag="SurfaceForegroundColor|0,0,0" Click="OnColorPreset" Background="#FF000000"/>
                                    <Button Style="{StaticResource ColorSwatchButton}" ToolTip="Red" Tag="SurfaceForegroundColor|255,0,0" Click="OnColorPreset" Background="#FFFF0000"/>
                                    <Button Style="{StaticResource ColorSwatchButton}" ToolTip="Green" Tag="SurfaceForegroundColor|0,255,0" Click="OnColorPreset" Background="#FF00FF00"/>
                                    <Button Style="{StaticResource ColorSwatchButton}" ToolTip="Blue" Tag="SurfaceForegroundColor|0,0,255" Click="OnColorPreset" Background="#FF0000FF"/>
                                    <Button Style="{StaticResource ColorSwatchButton}" ToolTip="Yellow" Tag="SurfaceForegroundColor|255,255,0" Click="OnColorPreset" Background="#FFFFFF00"/>
                                    <Button Style="{StaticResource ColorSwatchButton}" ToolTip="Gray" Tag="SurfaceForegroundColor|128,128,128" Click="OnColorPreset" Background="#FF808080"/>
                                    <Button MinWidth="64" Height="22" Content="By View" Tag="SurfaceForegroundColor|ByView" Click="OnColorPreset" Style="{StaticResource CompactSecondaryButton}"/>
                                </WrapPanel>

                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="185"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Surface Background Pattern" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                    <ComboBox x:Name="SurfaceBackgroundPatternCombo" Grid.Column="1" Height="24" SelectionChanged="OnProjectionSurfaceSettingChanged"/>
                                </Grid>

                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="185"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="56"/>
                                        <ColumnDefinition Width="56"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Surface Background Color" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                    <Border x:Name="SurfaceBackgroundColorPreview" Grid.Column="1" Height="22" CornerRadius="3" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" Background="{StaticResource CardBackground}" Margin="0,0,6,0">
                                        <TextBlock x:Name="SurfaceBackgroundColorText" Text="By View" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                                    </Border>
                                    <Button Grid.Column="2" Content="Pick" Tag="SurfaceBackgroundColor" Style="{StaticResource CompactPrimaryButton}" Margin="0,0,4,0" Click="OnPickColor"/>
                                    <Button Grid.Column="3" Content="By" Tag="SurfaceBackgroundColor" Style="{StaticResource CompactSecondaryButton}" Click="OnClearColor"/>
                                </Grid>
                                <WrapPanel Margin="185,4,0,0">
                                    <Button Style="{StaticResource ColorSwatchButton}" ToolTip="Black" Tag="SurfaceBackgroundColor|0,0,0" Click="OnColorPreset" Background="#FF000000"/>
                                    <Button Style="{StaticResource ColorSwatchButton}" ToolTip="Red" Tag="SurfaceBackgroundColor|255,0,0" Click="OnColorPreset" Background="#FFFF0000"/>
                                    <Button Style="{StaticResource ColorSwatchButton}" ToolTip="Green" Tag="SurfaceBackgroundColor|0,255,0" Click="OnColorPreset" Background="#FF00FF00"/>
                                    <Button Style="{StaticResource ColorSwatchButton}" ToolTip="Blue" Tag="SurfaceBackgroundColor|0,0,255" Click="OnColorPreset" Background="#FF0000FF"/>
                                    <Button Style="{StaticResource ColorSwatchButton}" ToolTip="Yellow" Tag="SurfaceBackgroundColor|255,255,0" Click="OnColorPreset" Background="#FFFFFF00"/>
                                    <Button Style="{StaticResource ColorSwatchButton}" ToolTip="Gray" Tag="SurfaceBackgroundColor|128,128,128" Click="OnColorPreset" Background="#FF808080"/>
                                    <Button MinWidth="64" Height="22" Content="By View" Tag="SurfaceBackgroundColor|ByView" Click="OnColorPreset" Style="{StaticResource CompactSecondaryButton}"/>
                                </WrapPanel>

                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="185"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Transparency (0-100)" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                    <ComboBox x:Name="TransparencyCombo" Grid.Column="1" Height="24"/>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Cut">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="8">
                                <CheckBox x:Name="UseProjectionSurfaceColorsForCutCheckBox"
                                          Content="Use Projection / Surface settings for Cut"
                                          Style="{StaticResource ModernCheckBox}"
                                          Margin="0,0,0,4"
                                          Checked="OnUseProjectionSurfaceColorsForCutChanged"
                                          Unchecked="OnUseProjectionSurfaceColorsForCutChanged"/>

                                <TextBlock x:Name="CutLinkNoticeText"
                                           Margin="0,0,0,8"
                                           Foreground="{StaticResource TextSecondary}"
                                           Text="Cut line, pattern, weight, and fill settings are linked to the Projection / Surface tab."
                                           TextWrapping="Wrap"
                                           Visibility="Collapsed"/>

                                <StackPanel x:Name="CutSettingsPanel">
                                    <TextBlock Text="Lines" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>

                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="185"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="56"/>
                                            <ColumnDefinition Width="56"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Cut Line Color" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                        <Border x:Name="CutLineColorPreview" Grid.Column="1" Height="22" CornerRadius="3" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" Background="{StaticResource CardBackground}" Margin="0,0,6,0">
                                            <TextBlock x:Name="CutLineColorText" Text="By View" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                                        </Border>
                                        <Button x:Name="CutLineColorPickButton" Grid.Column="2" Content="Pick" Tag="CutLineColor" Style="{StaticResource CompactPrimaryButton}" Margin="0,0,4,0" Click="OnPickColor"/>
                                        <Button x:Name="CutLineColorClearButton" Grid.Column="3" Content="By" Tag="CutLineColor" Style="{StaticResource CompactSecondaryButton}" Click="OnClearColor"/>
                                    </Grid>
                                    <WrapPanel Margin="185,4,0,0">
                                        <Button Style="{StaticResource ColorSwatchButton}" ToolTip="Black" Tag="CutLineColor|0,0,0" Click="OnColorPreset" Background="#FF000000"/>
                                        <Button Style="{StaticResource ColorSwatchButton}" ToolTip="Red" Tag="CutLineColor|255,0,0" Click="OnColorPreset" Background="#FFFF0000"/>
                                        <Button Style="{StaticResource ColorSwatchButton}" ToolTip="Green" Tag="CutLineColor|0,255,0" Click="OnColorPreset" Background="#FF00FF00"/>
                                        <Button Style="{StaticResource ColorSwatchButton}" ToolTip="Blue" Tag="CutLineColor|0,0,255" Click="OnColorPreset" Background="#FF0000FF"/>
                                        <Button Style="{StaticResource ColorSwatchButton}" ToolTip="Yellow" Tag="CutLineColor|255,255,0" Click="OnColorPreset" Background="#FFFFFF00"/>
                                        <Button Style="{StaticResource ColorSwatchButton}" ToolTip="Gray" Tag="CutLineColor|128,128,128" Click="OnColorPreset" Background="#FF808080"/>
                                        <Button MinWidth="64" Height="22" Content="By View" Tag="CutLineColor|ByView" Click="OnColorPreset" Style="{StaticResource CompactSecondaryButton}"/>
                                    </WrapPanel>

                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="185"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Cut Line Pattern" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                        <ComboBox x:Name="CutLinePatternCombo" Grid.Column="1" Height="24"/>
                                    </Grid>

                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="185"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Cut Line Weight" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                        <ComboBox x:Name="CutLineWeightCombo" Grid.Column="1" Height="24"/>
                                    </Grid>

                                    <Separator Margin="0,8,0,8"/>
                                    <TextBlock Text="Patterns" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>

                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="185"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Cut Foreground Pattern" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                        <ComboBox x:Name="CutForegroundPatternCombo" Grid.Column="1" Height="24"/>
                                    </Grid>

                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="185"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="56"/>
                                            <ColumnDefinition Width="56"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Cut Foreground Color" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                        <Border x:Name="CutForegroundColorPreview" Grid.Column="1" Height="22" CornerRadius="3" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" Background="{StaticResource CardBackground}" Margin="0,0,6,0">
                                            <TextBlock x:Name="CutForegroundColorText" Text="By View" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                                        </Border>
                                        <Button x:Name="CutForegroundColorPickButton" Grid.Column="2" Content="Pick" Tag="CutForegroundColor" Style="{StaticResource CompactPrimaryButton}" Margin="0,0,4,0" Click="OnPickColor"/>
                                        <Button x:Name="CutForegroundColorClearButton" Grid.Column="3" Content="By" Tag="CutForegroundColor" Style="{StaticResource CompactSecondaryButton}" Click="OnClearColor"/>
                                    </Grid>
                                    <WrapPanel Margin="185,4,0,0">
                                        <Button Style="{StaticResource ColorSwatchButton}" ToolTip="Black" Tag="CutForegroundColor|0,0,0" Click="OnColorPreset" Background="#FF000000"/>
                                        <Button Style="{StaticResource ColorSwatchButton}" ToolTip="Red" Tag="CutForegroundColor|255,0,0" Click="OnColorPreset" Background="#FFFF0000"/>
                                        <Button Style="{StaticResource ColorSwatchButton}" ToolTip="Green" Tag="CutForegroundColor|0,255,0" Click="OnColorPreset" Background="#FF00FF00"/>
                                        <Button Style="{StaticResource ColorSwatchButton}" ToolTip="Blue" Tag="CutForegroundColor|0,0,255" Click="OnColorPreset" Background="#FF0000FF"/>
                                        <Button Style="{StaticResource ColorSwatchButton}" ToolTip="Yellow" Tag="CutForegroundColor|255,255,0" Click="OnColorPreset" Background="#FFFFFF00"/>
                                        <Button Style="{StaticResource ColorSwatchButton}" ToolTip="Gray" Tag="CutForegroundColor|128,128,128" Click="OnColorPreset" Background="#FF808080"/>
                                        <Button MinWidth="64" Height="22" Content="By View" Tag="CutForegroundColor|ByView" Click="OnColorPreset" Style="{StaticResource CompactSecondaryButton}"/>
                                    </WrapPanel>

                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="185"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Cut Background Pattern" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                        <ComboBox x:Name="CutBackgroundPatternCombo" Grid.Column="1" Height="24"/>
                                    </Grid>

                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="185"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="56"/>
                                            <ColumnDefinition Width="56"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Cut Background Color" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                        <Border x:Name="CutBackgroundColorPreview" Grid.Column="1" Height="22" CornerRadius="3" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" Background="{StaticResource CardBackground}" Margin="0,0,6,0">
                                            <TextBlock x:Name="CutBackgroundColorText" Text="By View" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                                        </Border>
                                        <Button x:Name="CutBackgroundColorPickButton" Grid.Column="2" Content="Pick" Tag="CutBackgroundColor" Style="{StaticResource CompactPrimaryButton}" Margin="0,0,4,0" Click="OnPickColor"/>
                                        <Button x:Name="CutBackgroundColorClearButton" Grid.Column="3" Content="By" Tag="CutBackgroundColor" Style="{StaticResource CompactSecondaryButton}" Click="OnClearColor"/>
                                    </Grid>
                                    <WrapPanel Margin="185,4,0,0">
                                        <Button Style="{StaticResource ColorSwatchButton}" ToolTip="Black" Tag="CutBackgroundColor|0,0,0" Click="OnColorPreset" Background="#FF000000"/>
                                        <Button Style="{StaticResource ColorSwatchButton}" ToolTip="Red" Tag="CutBackgroundColor|255,0,0" Click="OnColorPreset" Background="#FFFF0000"/>
                                        <Button Style="{StaticResource ColorSwatchButton}" ToolTip="Green" Tag="CutBackgroundColor|0,255,0" Click="OnColorPreset" Background="#FF00FF00"/>
                                        <Button Style="{StaticResource ColorSwatchButton}" ToolTip="Blue" Tag="CutBackgroundColor|0,0,255" Click="OnColorPreset" Background="#FF0000FF"/>
                                        <Button Style="{StaticResource ColorSwatchButton}" ToolTip="Yellow" Tag="CutBackgroundColor|255,255,0" Click="OnColorPreset" Background="#FFFFFF00"/>
                                        <Button Style="{StaticResource ColorSwatchButton}" ToolTip="Gray" Tag="CutBackgroundColor|128,128,128" Click="OnColorPreset" Background="#FF808080"/>
                                        <Button MinWidth="64" Height="22" Content="By View" Tag="CutBackgroundColor|ByView" Click="OnColorPreset" Style="{StaticResource CompactSecondaryButton}"/>
                                    </WrapPanel>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>

                <CheckBox x:Name="HalftoneCheckBox"
                          Grid.Row="4"
                          Content="Enable Halftone"
                          Style="{StaticResource ToggleSwitchCheckBox}"
                          Margin="0,8,0,0"/>

                <TextBlock x:Name="ErrorText"
                           Grid.Row="5"
                           Foreground="{StaticResource AccentDanger}"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1"
                    Content="Reset"
                    Style="{StaticResource SecondaryButton}"
                    MinWidth="110"
                    Margin="0,0,6,0"
                    Click="OnReset"/>
            <Button Grid.Column="2"
                    Content="Apply"
                    Style="{StaticResource ModernButton}"
                    IsDefault="True"
                    MinWidth="110"
                    Margin="0,0,6,0"
                    Click="OnOk"/>
            <Button Grid.Column="3"
                    Content="Cancel"
                    Style="{StaticResource SecondaryButton}"
                    IsCancel="True"
                    MinWidth="110"
                    Click="OnCancel"/>
        </Grid>
    </Grid>
</Window>
