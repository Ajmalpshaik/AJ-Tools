                                                          VerticalAlignment="Center"
                                                          Margin="10,0,0,0"
                                                          IsHitTestVisible="False">
                                                        <Ellipse Width="8"
                                                                 Height="8"
                                                                 HorizontalAlignment="Left"
                                                                 VerticalAlignment="Top"
                                                                 Stroke="{StaticResource TextDisabledBrush}"
                                                                 StrokeThickness="1.4"/>
                                                        <Line X1="7"
                                                              Y1="7"
                                                              X2="12"
                                                              Y2="12"
                                                              Stroke="{StaticResource TextDisabledBrush}"
                                                              StrokeThickness="1.4"
                                                              StrokeStartLineCap="Round"
                                                              StrokeEndLineCap="Round"/>
                                                    </Grid>
                                                    <TextBlock x:Name="CategorySearchPlaceholderText"
                                                               Text="Search Categories..."
                                                               Foreground="{StaticResource TextDisabledBrush}"
                                                               FontSize="10"
                                                               VerticalAlignment="Center"
                                                               Margin="29,0,0,0"
                                                               IsHitTestVisible="False"/>
                                                </Grid>

                                                <Button Grid.Column="1"
                                                        Content="ALL"
                                                        Style="{StaticResource SmallSecondaryButtonStyle}"
                                                        Margin="0,0,8,0"
                                                        Click="OnSelectAllCategories"/>
                                                <Button Grid.Column="2"
                                                        Content="NONE"
                                                        Style="{StaticResource SmallSecondaryButtonStyle}"
                                                        Click="OnClearCategories"/>
                                            </Grid>

                                            <ListBox x:Name="CategoryListBox"
                                                     Grid.Row="1"
                                                     MinHeight="288"
                                                     Margin="0,12,0,0"
                                                     Style="{StaticResource CategoryListBoxStyle}"
                                                     ItemContainerStyle="{StaticResource CategoryListBoxItemStyle}">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                  Content="{Binding DisplayName}"
                                                                  HorizontalAlignment="Stretch"
                                                                  Style="{StaticResource CategoryCheckBoxStyle}"/>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </TabItem>
                        </TabControl>

                        <TextBlock x:Name="ErrorText"
                                   Grid.Row="1"
                                   Foreground="#FFFF7C7C"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="0,12,0,0"/>
                    </Grid>
                </Border>
            </ScrollViewer>

            <Border Grid.Row="2"
                    Background="{StaticResource ShellBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="0,1,0,0"
                    Padding="14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Content="RESET"
                            Style="{StaticResource FooterSecondaryButtonStyle}"
                            Click="OnReset"/>
                    <TextBlock Grid.Column="1"
                               Text="Copyright © 2026 Ajmal P.S. All Rights Reserved."
                               Foreground="{StaticResource TextDisabledBrush}"
                               FontSize="10"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal">
                        <Button x:Name="ApplyElementsButton"
                                Content="ELEMENTS"
                                Style="{StaticResource FooterPrimaryButtonStyle}"
                                IsDefault="True"
                                Margin="0,0,8,0"
                                Click="OnApplyElements"/>
                        <Button x:Name="ApplyCategoriesButton"
                                Content="CATEGORIES"
                                Style="{StaticResource FooterPrimaryButtonStyle}"
                                Margin="0,0,8,0"
                                Click="OnApplyCategories"/>
                        <Button Content="CANCEL"
                                Style="{StaticResource FooterDangerButtonStyle}"
                                IsCancel="True"
                                Click="OnCancel"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
