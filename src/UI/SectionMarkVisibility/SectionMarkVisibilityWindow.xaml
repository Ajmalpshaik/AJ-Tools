<Window x:Class="AJTools.UI.SectionMarkVisibility.SectionMarkVisibilityWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Section Mark Visibility"
        Width="500"
        Height="460"
        MinWidth="440"
        MinHeight="400"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundDark}"
        Foreground="{DynamicResource TextPrimary}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../ModernStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Margin="0,0,0,8">
            <StackPanel>
                <!-- Card 1: Run Scope -->
                <Border Style="{StaticResource PanelCard}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Run Scope"
                                   Style="{StaticResource SubtitleText}"
                                   Margin="0,0,0,8"/>

                        <RadioButton x:Name="ActiveViewOnlyRadio"
                                     Content="Active plan view only"
                                     Style="{StaticResource ModernRadioButton}"
                                     IsChecked="True"
                                     Checked="OnRunScopeChanged"
                                     Unchecked="OnRunScopeChanged"/>

                        <RadioButton x:Name="MultipleViewsRadio"
                                     Content="Choose multiple plan views"
                                     Style="{StaticResource ModernRadioButton}"
                                     Checked="OnRunScopeChanged"
                                     Unchecked="OnRunScopeChanged"/>
                    </StackPanel>
                </Border>

                <!-- Card 2: Sheet Number Filter -->
                <Border x:Name="SheetFilterCard" Style="{StaticResource PanelCard}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Sheet Number Filtering"
                                   Style="{StaticResource SubtitleText}"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="Sections placed on matching sheet numbers remain visible. Others will be hidden."
                                   Style="{StaticResource DisabledText}"
                                   Margin="0,0,0,8"
                                   TextWrapping="Wrap"/>

                        <!-- Dynamic Rows ItemsControl -->
                        <ItemsControl x:Name="SheetNumbersItemsControl" Margin="0,0,0,8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding SheetNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource ModernTextBox}"
                                                 Grid.Column="0"
                                                 Margin="0,0,8,0"
                                                 ToolTip="Enter Sheet Number (e.g. M-401)"/>
                                        <Button Content="✕"
                                                Grid.Column="1"
                                                Style="{StaticResource DangerButton}"
                                                MinWidth="34"
                                                MinHeight="34"
                                                Width="34"
                                                Height="34"
                                                Padding="0"
                                                Click="OnRemoveRow"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Add Row Button -->
                        <Button Content="+ Add Sheet Number"
                                Style="{StaticResource ModernButton}"
                                MinWidth="180"
                                HorizontalAlignment="Left"
                                Margin="0,4,0,0"
                                Click="OnAddRow"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Error Text -->
        <TextBlock x:Name="ErrorText"
                   Grid.Row="1"
                   Foreground="{StaticResource AccentDanger}"
                   FontWeight="SemiBold"
                   Margin="2,4,0,8"
                   TextWrapping="Wrap"/>

        <!-- Action Button Bar -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left side: Action Buttons -->
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button x:Name="ApplyButton"
                        Content="Apply Filter"
                        Style="{StaticResource ModernButton}"
                        IsDefault="True"
                        MinWidth="120"
                        Margin="0,0,8,0"
                        Click="OnApplyFilter"/>

                <Button x:Name="KeepPlacedButton"
                        Content="Keep All Placed"
                        Style="{StaticResource SuccessButton}"
                        MinWidth="120"
                        Margin="0,0,8,0"
                        Click="OnKeepAllPlaced"/>

                <Button x:Name="UnhideAllButton"
                        Content="Unhide All"
                        Style="{StaticResource SecondaryButton}"
                        MinWidth="100"
                        Click="OnUnhideAll"/>
            </StackPanel>

            <!-- Right side: Cancel -->
            <Button Grid.Column="1"
                    Content="Cancel"
                    Style="{StaticResource SecondaryButton}"
                    IsCancel="True"
                    MinWidth="100"
                    Click="OnCancel"/>
        </Grid>

        <!-- Footer -->
        <TextBlock Grid.Row="3"
                   Text="Created &amp; All Rights Reserved @ Ajmal P.S."
                   Foreground="{StaticResource TextDisabled}"
                   FontSize="10"
                   HorizontalAlignment="Center"
                   Margin="0,8,0,0"
                   FontStyle="Italic"/>
    </Grid>
</Window>
