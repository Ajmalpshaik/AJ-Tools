<!--
  Tool Name: Transfer View Templates UI
  Description: Selects source/target documents and view templates to transfer.
  Author: Ajmal P.S.
  Version: 1.0.0
  Last Updated: 2026-04-14
  Revit Version: 2020
  Dependencies: Autodesk.Revit.DB, Autodesk.Revit.UI, System.Windows
-->
<Window x:Class="AJTools.UI.TransferViewTemplatesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Transfer View Templates - AJ Tools"
        Width="760"
        Height="760"
        MinWidth="620"
        MinHeight="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{DynamicResource BackgroundDark}"
        Foreground="{DynamicResource TextPrimary}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ModernStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource CardBackground}"
                CornerRadius="8"
                Padding="12"
                Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="Transfer View Templates"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}"/>
                <TextBlock Text="Copy selected view templates between open project files."
                           Margin="0,4,0,0"
                           Foreground="{StaticResource TextSecondary}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Background="{StaticResource CardBackground}"
                CornerRadius="8"
                Padding="12"
                Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Margin="0,0,8,8"
                           Foreground="{StaticResource TextSecondary}"
                           Text="Copy From:"/>
                <ComboBox x:Name="SourceDocCombo"
                          Grid.Row="0"
                          Grid.Column="1"
                          Height="30"
                          Margin="0,0,0,8"
                          DisplayMemberPath="DisplayName"/>

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Margin="0,0,8,8"
                           Foreground="{StaticResource TextSecondary}"
                           Text="Copy To:"/>
                <ComboBox x:Name="TargetDocCombo"
                          Grid.Row="1"
                          Grid.Column="1"
                          Height="30"
                          Margin="0,0,0,8"
                          DisplayMemberPath="DisplayName"/>

                <CheckBox x:Name="OverrideCheckBox"
                          Grid.Row="2"
                          Grid.ColumnSpan="2"
                          Content="Override templates with same name in target project"
                          IsChecked="True"
                          Style="{StaticResource ToggleSwitchCheckBox}"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       Foreground="{StaticResource TextSecondary}"
                       Text="Filter:"/>
            <TextBox x:Name="FilterTextBox"
                     Grid.Column="1"
                     MinHeight="34"
                     Style="{StaticResource ModernTextBox}"
                     VerticalContentAlignment="Center"/>
            <TextBlock x:Name="CountText"
                       Grid.Column="2"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0"
                       Foreground="{StaticResource TextSecondary}"/>
        </Grid>

        <ListBox x:Name="TemplatesListBox"
                 Grid.Row="3"
                 Style="{StaticResource ModernListBox}"
                 ItemContainerStyle="{StaticResource ModernListBoxItem}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox Content="{Binding Name}"
                              IsChecked="{Binding IsChecked, Mode=TwoWay}"
                              Style="{StaticResource ModernCheckBox}"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Border Grid.Row="4"
                Background="{StaticResource CardBackground}"
                CornerRadius="8"
                Padding="10"
                Margin="0,8,0,8">
            <StackPanel>
                <TextBlock Text="Warning"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource AccentOrange}"/>
                <TextBlock Text="Transferring templates can also copy filters and dependent settings."
                           Margin="0,4,0,0"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource TextSecondary}"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="StatusText"
                       Grid.Column="0"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource TextSecondary}"
                       TextWrapping="Wrap"
                       Margin="0,0,12,0"/>

            <Button x:Name="SelectAllButton"
                    Grid.Column="1"
                    Content="Select All"
                    Style="{StaticResource SecondaryButton}"
                    MinWidth="110"
                    Margin="0,0,8,0"/>
            <Button x:Name="SelectNoneButton"
                    Grid.Column="2"
                    Content="Select None"
                    Style="{StaticResource SecondaryButton}"
                    MinWidth="110"
                    Margin="0,0,8,0"/>
            <Button x:Name="TransferButton"
                    Grid.Column="3"
                    Content="Transfer"
                    Style="{StaticResource ModernButton}"
                    IsDefault="True"
                    MinWidth="120"
                    Margin="0,0,8,0"/>
            <Button x:Name="CancelButton"
                    Grid.Column="4"
                    Content="Cancel"
                    Style="{StaticResource SecondaryButton}"
                    IsCancel="True"
                    MinWidth="110"/>
        </Grid>
    </Grid>
</Window>
