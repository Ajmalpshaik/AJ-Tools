<Window x:Class="AJTools.UI.MepOpenings.MepOpeningSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Opening Settings"
        Width="1120"
        Height="800"
        MinWidth="980"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{DynamicResource BackgroundDark}"
        Foreground="{DynamicResource TextPrimary}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../ModernStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="HeaderLabel" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin" Value="0,0,0,6"/>
            </Style>

            <Style x:Key="OpeningDataGrid" TargetType="DataGrid">
                <Setter Property="Background" Value="{StaticResource CardBackground}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderSoft}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="GridLinesVisibility" Value="Horizontal"/>
                <Setter Property="HeadersVisibility" Value="Column"/>
                <Setter Property="RowHeaderWidth" Value="0"/>
                <Setter Property="AutoGenerateColumns" Value="False"/>
                <Setter Property="CanUserAddRows" Value="False"/>
                <Setter Property="CanUserDeleteRows" Value="False"/>
                <Setter Property="CanUserReorderColumns" Value="False"/>
                <Setter Property="CanUserResizeRows" Value="False"/>
                <Setter Property="SelectionMode" Value="Single"/>
                <Setter Property="SelectionUnit" Value="Cell"/>
            </Style>

            <Style TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="{StaticResource BackgroundMedium}"/>
                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Padding" Value="10,8"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderSoft}"/>
                <Setter Property="BorderThickness" Value="0,0,1,1"/>
            </Style>

            <Style TargetType="DataGridCell">
                <Setter Property="Background" Value="{StaticResource CardBackground}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderSoft}"/>
                <Setter Property="BorderThickness" Value="0,0,1,0"/>
                <Setter Property="Padding" Value="8,4"/>
            </Style>

            <Style x:Key="OpeningRuleComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                <Setter Property="Opacity" Value="1"/>
                <Style.Triggers>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Opacity" Value="0.45"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource BackgroundMedium}"
                BorderBrush="{StaticResource BorderSoft}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14"
                Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Opening Settings" Style="{StaticResource TitleText}"/>
                <TextBlock Text="Opening shape, cutout buffer, insulation, and merge distance"
                           Style="{StaticResource SubtitleText}"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource PanelCard}"
                    Margin="0,0,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0"
                                Grid.Column="0"
                                Margin="0,0,24,16">
                        <TextBlock Text="Opening Method"
                                   Style="{StaticResource HeaderLabel}"/>
                        <ComboBox ItemsSource="{Binding OpeningModeChoices}"
                                  SelectedValuePath="Mode"
                                  SelectedValue="{Binding CreationMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  MinHeight="32">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Row="0"
                                Grid.Column="1"
                                Margin="0,0,0,16">
                        <TextBlock Text="Selection Method"
                                   Style="{StaticResource HeaderLabel}"/>
                        <ComboBox ItemsSource="{Binding OpeningSelectionMethodChoices}"
                                  SelectedValuePath="Method"
                                  SelectedValue="{Binding SelectionMethod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  MinHeight="32">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,24,0">
                        <TextBlock Text="Opening Sources"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Content="Current Model"
                                         GroupName="OpeningSourceModelScope"
                                         IsChecked="{Binding UseCurrentModelSources, Mode=TwoWay}"
                                         Foreground="{StaticResource TextPrimary}"
                                         Style="{StaticResource ModernRadioButton}"
                                         Margin="0,0,22,0"/>
                            <RadioButton Content="Linked Models"
                                         GroupName="OpeningSourceModelScope"
                                         IsChecked="{Binding UseLinkedModelSources, Mode=TwoWay}"
                                         Foreground="{StaticResource TextPrimary}"
                                         Style="{StaticResource ModernRadioButton}"/>
                        </StackPanel>
                        <TextBlock Text="Linked Source Model"
                                   Style="{StaticResource HeaderLabel}"
                                   Margin="0,14,0,6"/>
                        <ComboBox ItemsSource="{Binding OpeningLinkChoices}"
                                  SelectedValuePath="UniqueId"
                                  SelectedValue="{Binding SelectedSourceLinkUniqueId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  IsEnabled="{Binding IsSourceLinkPickerEnabled}"
                                  MinHeight="32">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="1">
                        <TextBlock Text="Opening Hosts"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Content="Current Model"
                                         GroupName="OpeningHostModelScope"
                                         IsChecked="{Binding UseCurrentModelHosts, Mode=TwoWay}"
                                         Foreground="{StaticResource TextPrimary}"
                                         Style="{StaticResource ModernRadioButton}"
                                         Margin="0,0,22,0"/>
                            <RadioButton Content="Linked Models"
                                         GroupName="OpeningHostModelScope"
                                         IsChecked="{Binding UseLinkedModelHosts, Mode=TwoWay}"
                                         Foreground="{StaticResource TextPrimary}"
                                         Style="{StaticResource ModernRadioButton}"/>
                        </StackPanel>
                        <TextBlock Text="Linked Host Model"
                                   Style="{StaticResource HeaderLabel}"
                                   Margin="0,14,0,6"/>
                        <ComboBox ItemsSource="{Binding OpeningLinkChoices}"
                                  SelectedValuePath="UniqueId"
                                  SelectedValue="{Binding SelectedHostLinkUniqueId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  IsEnabled="{Binding IsHostLinkPickerEnabled}"
                                  MinHeight="32">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Style="{StaticResource PanelCard}"
                    MinHeight="210">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Element Rules"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10"/>

                    <DataGrid Grid.Row="1"
                              x:Name="RulesGrid"
                              Style="{StaticResource OpeningDataGrid}"
                              ItemsSource="{Binding Rules}"
                              MinHeight="160"
                              RowHeight="30"
                              ColumnHeaderHeight="32"
                              VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Use" Width="0.55*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsIncluded, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Style="{StaticResource ModernCheckBox}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Element"
                                                Binding="{Binding ElementName}"
                                                Width="1.35*"
                                                IsReadOnly="True"/>

                            <DataGridTemplateColumn Header="Shape" Width="1.35*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding ShapeChoices}"
                                                  SelectedItem="{Binding Shape, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  IsEnabled="{Binding DataContext.IsShapeSelectionEnabled, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  MinHeight="28"
                                                  Style="{StaticResource OpeningRuleComboBoxStyle}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Cutout Buffer (mm)"
                                                Binding="{Binding CutoutBufferMm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=0.##}"
                                                Width="1.7*"/>

                            <DataGridTemplateColumn Header="Vertical Family" Width="2.5*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding DataContext.OpeningFamilyChoices, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  SelectedItem="{Binding VerticalOpeningFamilyName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  IsEnabled="{Binding DataContext.IsOpeningFamilyEnabled, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  MinHeight="28"
                                                  Style="{StaticResource OpeningRuleComboBoxStyle}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Horizontal Family" Width="2.5*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding DataContext.OpeningFamilyChoices, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  SelectedItem="{Binding HorizontalOpeningFamilyName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  IsEnabled="{Binding DataContext.IsOpeningFamilyEnabled, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  MinHeight="28"
                                                  Style="{StaticResource OpeningRuleComboBoxStyle}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Style="{StaticResource PanelCard}"
                    Margin="0,12,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,18,0">
                        <TextBlock Text="Merge Distance" Style="{StaticResource HeaderLabel}"/>
                        <TextBlock Text="Nearby selected crossings on the same host become one rectangular opening."
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <TextBox Grid.Row="0"
                             Grid.Column="1"
                             x:Name="TxtMergeDistance"
                             Text="{Binding MergeDistanceText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             TextAlignment="Center"
                             VerticalContentAlignment="Center"
                             Style="{StaticResource ModernTextBox}"
                             MinHeight="34"/>
                    <TextBlock Grid.Row="0"
                               Grid.Column="2"
                               Text="mm"
                               Foreground="{StaticResource TextSecondary}"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0"/>

                    <CheckBox Grid.Row="1"
                              Grid.Column="0"
                              Grid.ColumnSpan="3"
                              x:Name="ChkIncludeInsulation"
                              Content="Include pipe and duct insulation when it exists"
                              IsChecked="{Binding IncludeInsulation, Mode=TwoWay}"
                              Foreground="{StaticResource TextPrimary}"
                              Style="{StaticResource ModernCheckBox}"
                              Margin="0,14,0,0"/>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="TxtStatus"
                       Grid.Column="0"
                       Text=""
                       Foreground="{StaticResource TextSecondary}"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="1"
                    Content="Save"
                    Width="110"
                    Style="{StaticResource ModernButton}"
                    Margin="0,0,8,0"
                    Click="BtnSave_Click"/>
            <Button Grid.Column="2"
                    Content="Close"
                    Width="110"
                    Style="{StaticResource SecondaryButton}"
                    Click="BtnClose_Click"/>
        </Grid>
    </Grid>
</Window>
