<Window x:Class="AJTools.UI.Purge.PurgeUnusedFamilyParametersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Purge Unused Family Parameters - AJ Tools"
        Width="1160"
        Height="730"
        MinWidth="960"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundDark}"
        Foreground="{DynamicResource TextPrimary}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../ModernStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="SummaryLabelText" TargetType="TextBlock" BasedOn="{StaticResource BodyText}">
                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                <Setter Property="FontSize" Value="11"/>
            </Style>

            <Style x:Key="SummaryValueText" TargetType="TextBlock" BasedOn="{StaticResource SubtitleText}">
                <Setter Property="FontSize" Value="19"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>

            <Style x:Key="DetailText" TargetType="TextBlock" BasedOn="{StaticResource BodyText}">
                <Setter Property="TextWrapping" Value="Wrap"/>
                <Setter Property="Margin" Value="0,2,0,2"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource PanelCard}" Padding="14" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Purge Unused Family Parameters" Style="{StaticResource TitleText}"/>
                <TextBlock Margin="0,4,0,0"
                           Foreground="{StaticResource TextSecondary}"
                           TextWrapping="Wrap"
                           Text="Scan current family parameters, classify dependency usage, and safely remove selected unused candidates."/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelCard}" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Summary" Style="{StaticResource SubtitleText}"/>
                    <UniformGrid Grid.Row="1" Margin="0,10,0,0" Rows="1" Columns="5">
                        <StackPanel>
                            <TextBlock Text="Total Scanned" Style="{StaticResource SummaryLabelText}"/>
                            <TextBlock x:Name="txtTotalScanned" Text="0" Style="{StaticResource SummaryValueText}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Safe to Purge" Style="{StaticResource SummaryLabelText}"/>
                            <TextBlock x:Name="txtSafeCount" Text="0" Style="{StaticResource SummaryValueText}" Foreground="{StaticResource AccentGreen}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Possibly Unused" Style="{StaticResource SummaryLabelText}"/>
                            <TextBlock x:Name="txtPossibleCount" Text="0" Style="{StaticResource SummaryValueText}" Foreground="{StaticResource AccentOrange}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="In Use" Style="{StaticResource SummaryLabelText}"/>
                            <TextBlock x:Name="txtInUseCount" Text="0" Style="{StaticResource SummaryValueText}" Foreground="{StaticResource AccentBlue}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Cannot Delete" Style="{StaticResource SummaryLabelText}"/>
                            <TextBlock x:Name="txtCannotDeleteCount" Text="0" Style="{StaticResource SummaryValueText}" Foreground="{StaticResource AccentDanger}"/>
                        </StackPanel>
                    </UniformGrid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource PanelCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Filter" Style="{StaticResource SubtitleText}"/>

                    <TextBlock Grid.Row="1" Margin="0,10,0,4" Text="Search Parameter"/>
                    <TextBox x:Name="txtSearch"
                             Grid.Row="2"
                             Style="{StaticResource ModernTextBox}"
                             TextChanged="OnSearchTextChanged"/>

                    <TextBlock Grid.Row="3" Margin="0,10,0,4" Text="Status"/>
                    <ComboBox x:Name="cmbStatusFilter"
                              Grid.Row="4"
                              SelectionChanged="OnStatusFilterChanged"
                              SelectedValuePath="Tag">
                        <ComboBoxItem Content="All" Tag="All" IsSelected="True"/>
                        <ComboBoxItem Content="Safe to Purge" Tag="SafeToPurge"/>
                        <ComboBoxItem Content="Possibly Unused" Tag="PossiblyUnused"/>
                        <ComboBoxItem Content="In Use" Tag="InUse"/>
                        <ComboBoxItem Content="Cannot Delete" Tag="CannotDelete"/>
                    </ComboBox>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource PanelCard}" Padding="0">
            <DataGrid x:Name="dgParameters"
                      Style="{StaticResource ModernDataGrid}"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="False"
                      SelectionMode="Extended"
                      SelectionUnit="FullRow"
                      RowDetailsVisibilityMode="VisibleWhenSelected"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Pick" Width="48">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          IsEnabled="{Binding CanSelectForDeletion}"
                                          Style="{StaticResource ModernCheckBox}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Parameter Name" Binding="{Binding ParameterName}" Width="220"/>
                    <DataGridTextColumn Header="Parameter Type" Binding="{Binding ParameterTypeText}" Width="130"/>
                    <DataGridTextColumn Header="Instance / Type" Binding="{Binding InstanceTypeText}" Width="98"/>
                    <DataGridTextColumn Header="Shared / Family" Binding="{Binding SourceText}" Width="102"/>
                    <DataGridTextColumn Header="Formula" Binding="{Binding FormulaFlagText}" Width="70"/>
                    <DataGridTextColumn Header="Reporting" Binding="{Binding ReportingFlagText}" Width="78"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="120"/>
                    <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="*"/>
                </DataGrid.Columns>

                <DataGrid.RowDetailsTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" CornerRadius="8" Margin="8,4,8,8" Padding="10" Background="{StaticResource BackgroundMedium}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Style="{StaticResource DetailText}">
                                    <Run Text="Group: "/><Run Text="{Binding ParameterGroupText}"/>
                                    <Run Text="   |   Storage: "/><Run Text="{Binding StorageTypeText}"/>
                                    <Run Text="   |   Id: "/><Run Text="{Binding ParameterIdValue}"/>
                                </TextBlock>

                                <TextBlock Grid.Row="1" Style="{StaticResource DetailText}">
                                    <Run Text="Formula: "/><Run Text="{Binding FormulaText}"/>
                                </TextBlock>

                                <TextBlock Grid.Row="2" Style="{StaticResource DetailText}">
                                    <Run Text="Referenced by formulas: "/><Run Text="{Binding ReferencedByFormulaNames}"/>
                                </TextBlock>

                                <TextBlock Grid.Row="3" Style="{StaticResource DetailText}">
                                    <Run Text="Dimension Labels: "/><Run Text="{Binding AssociatedDimensionCount}"/>
                                    <Run Text="   |   Nested Associations: "/><Run Text="{Binding AssociatedNestedParameterCount}"/>
                                    <Run Text="   |   Visibility: "/><Run Text="{Binding AssociatedWithVisibilityControls}"/>
                                    <Run Text="   |   Deletable: "/><Run Text="{Binding IsDeletable}"/>
                                </TextBlock>

                                <TextBlock Grid.Row="4" Style="{StaticResource DetailText}" Foreground="{StaticResource TextSecondary}" Text="{Binding DetailedNotes}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </DataGrid.RowDetailsTemplate>
            </DataGrid>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource PanelCard}" Margin="0,10,0,0">
            <StackPanel>
                <TextBlock Text="Detection Notes / API Limitations" Style="{StaticResource SubtitleText}"/>
                <TextBlock x:Name="txtLimitations"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource TextSecondary}"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="4" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button x:Name="btnScan"
                        Content="Scan"
                        Width="110"
                        Margin="0,0,8,0"
                        Style="{StaticResource ModernButton}"
                        Click="OnScanClick"/>
                <Button x:Name="btnSelectSafeOnly"
                        Content="Select Safe Only"
                        Width="140"
                        Margin="0,0,8,0"
                        Style="{StaticResource SecondaryButton}"
                        Click="OnSelectSafeOnlyClick"/>
                <Button x:Name="btnUnselectAll"
                        Content="Unselect All"
                        Width="120"
                        Style="{StaticResource SecondaryButton}"
                        Click="OnUnselectAllClick"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnDeleteSelected"
                        Content="Delete Selected"
                        Width="140"
                        Margin="0,0,8,0"
                        Style="{StaticResource DangerButton}"
                        Click="OnDeleteSelectedClick"/>
                <Button x:Name="btnClose"
                        Content="Close"
                        Width="110"
                        Style="{StaticResource SecondaryButton}"
                        IsCancel="True"
                        Click="OnCloseClick"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
