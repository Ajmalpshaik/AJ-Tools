<Window x:Class="AJTools.UI.Purge.PurgeUnplacedViewsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Purge Unplaced 3D Views and Sections - AJ Tools"
        Width="1040"
        Height="680"
        MinWidth="900"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundDark}"
        Foreground="{DynamicResource TextPrimary}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../ModernStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="SummaryLabelText" TargetType="TextBlock" BasedOn="{StaticResource BodyText}">
                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                <Setter Property="FontSize" Value="11"/>
            </Style>

            <Style x:Key="SummaryValueText" TargetType="TextBlock" BasedOn="{StaticResource SubtitleText}">
                <Setter Property="FontSize" Value="19"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>

            <Style x:Key="DetailText" TargetType="TextBlock" BasedOn="{StaticResource BodyText}">
                <Setter Property="TextWrapping" Value="Wrap"/>
                <Setter Property="Margin" Value="0,2,0,2"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource PanelCard}" Padding="14" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Purge Unplaced 3D Views and Sections" Style="{StaticResource TitleText}"/>
                <TextBlock Margin="0,4,0,0"
                           Foreground="{StaticResource TextSecondary}"
                           TextWrapping="Wrap"
                           Text="Review unplaced 3D and section views before deleting selected safe candidates from the active project."/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelCard}" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Summary" Style="{StaticResource SubtitleText}"/>
                    <UniformGrid Grid.Row="1" Margin="0,10,0,0" Rows="1" Columns="6">
                        <StackPanel>
                            <TextBlock Text="Found" Style="{StaticResource SummaryLabelText}"/>
                            <TextBlock x:Name="txtFoundCount" Text="0" Style="{StaticResource SummaryValueText}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="3D Views" Style="{StaticResource SummaryLabelText}"/>
                            <TextBlock x:Name="txt3DCount" Text="0" Style="{StaticResource SummaryValueText}" Foreground="{StaticResource AccentBlue}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Sections" Style="{StaticResource SummaryLabelText}"/>
                            <TextBlock x:Name="txtSectionCount" Text="0" Style="{StaticResource SummaryValueText}" Foreground="{StaticResource AccentMagenta}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Safe" Style="{StaticResource SummaryLabelText}"/>
                            <TextBlock x:Name="txtSafeCount" Text="0" Style="{StaticResource SummaryValueText}" Foreground="{StaticResource AccentGreen}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Skipped / Blocked" Style="{StaticResource SummaryLabelText}"/>
                            <TextBlock x:Name="txtBlockedCount" Text="0" Style="{StaticResource SummaryValueText}" Foreground="{StaticResource AccentOrange}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Selected" Style="{StaticResource SummaryLabelText}"/>
                            <TextBlock x:Name="txtSelectedCount" Text="0" Style="{StaticResource SummaryValueText}" Foreground="{StaticResource AccentDanger}"/>
                        </StackPanel>
                    </UniformGrid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource PanelCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Filter" Style="{StaticResource SubtitleText}"/>

                    <TextBlock Grid.Row="1" Margin="0,10,0,4" Text="Search View"/>
                    <TextBox x:Name="txtSearch"
                             Grid.Row="2"
                             Style="{StaticResource ModernTextBox}"
                             TextChanged="OnSearchTextChanged"/>

                    <TextBlock Grid.Row="3" Margin="0,10,0,4" Text="View Type"/>
                    <ComboBox x:Name="cmbKindFilter"
                              Grid.Row="4"
                              SelectionChanged="OnFilterChanged"
                              SelectedValuePath="Tag">
                        <ComboBoxItem Content="All" Tag="All" IsSelected="True"/>
                        <ComboBoxItem Content="3D Views" Tag="3D View"/>
                        <ComboBoxItem Content="Sections" Tag="Section"/>
                    </ComboBox>

                    <TextBlock Grid.Row="5" Margin="0,10,0,4" Text="Status"/>
                    <ComboBox x:Name="cmbStatusFilter"
                              Grid.Row="6"
                              SelectionChanged="OnFilterChanged"
                              SelectedValuePath="Tag">
                        <ComboBoxItem Content="All" Tag="All" IsSelected="True"/>
                        <ComboBoxItem Content="Safe to Purge" Tag="SafeToPurge"/>
                        <ComboBoxItem Content="Skipped" Tag="Skipped"/>
                        <ComboBoxItem Content="Cannot Delete" Tag="CannotDelete"/>
                    </ComboBox>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource PanelCard}" Padding="0">
            <DataGrid x:Name="dgViews"
                      Style="{StaticResource ModernDataGrid}"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="False"
                      SelectionMode="Extended"
                      SelectionUnit="FullRow"
                      RowDetailsVisibilityMode="VisibleWhenSelected"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Pick" Width="48">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          IsEnabled="{Binding CanSelectForDeletion}"
                                          Style="{StaticResource ModernCheckBox}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="View Name" Binding="{Binding ViewName}" Width="260"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding ViewKind}" Width="92"/>
                    <DataGridTextColumn Header="Element Id" Binding="{Binding ViewIdValue}" Width="86"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="116"/>
                    <DataGridTextColumn Header="Reason" Binding="{Binding StatusReason}" Width="*"/>
                </DataGrid.Columns>

                <DataGrid.RowDetailsTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" CornerRadius="8" Margin="8,4,8,8" Padding="10" Background="{StaticResource BackgroundMedium}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource DetailText}">
                                    <Run Text="Revit ViewType: "/><Run Text="{Binding ViewTypeText}"/>
                                    <Run Text="   |   Element Id: "/><Run Text="{Binding ViewIdValue}"/>
                                </TextBlock>
                                <TextBlock Style="{StaticResource DetailText}">
                                    <Run Text="Active View: "/><Run Text="{Binding IsActiveView}"/>
                                    <Run Text="   |   Default {3D}: "/><Run Text="{Binding IsDefault3DView}"/>
                                    <Run Text="   |   Deletable: "/><Run Text="{Binding IsDeletable}"/>
                                </TextBlock>
                                <TextBlock Style="{StaticResource DetailText}" Foreground="{StaticResource TextSecondary}" Text="{Binding DetailedNotes}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </DataGrid.RowDetailsTemplate>
            </DataGrid>
        </Border>

        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button x:Name="btnScan"
                        Content="Scan"
                        Width="110"
                        Margin="0,0,8,0"
                        Style="{StaticResource ModernButton}"
                        Click="OnScanClick"/>
                <Button x:Name="btnSelectSafeOnly"
                        Content="Select Safe"
                        Width="120"
                        Margin="0,0,8,0"
                        Style="{StaticResource SecondaryButton}"
                        Click="OnSelectSafeOnlyClick"/>
                <Button x:Name="btnUnselectAll"
                        Content="Unselect All"
                        Width="120"
                        Style="{StaticResource SecondaryButton}"
                        Click="OnUnselectAllClick"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnDeleteSelected"
                        Content="Delete Selected"
                        Width="140"
                        Margin="0,0,8,0"
                        Style="{StaticResource DangerButton}"
                        Click="OnDeleteSelectedClick"/>
                <Button x:Name="btnClose"
                        Content="Close"
                        Width="110"
                        Style="{StaticResource SecondaryButton}"
                        IsCancel="True"
                        Click="OnCloseClick"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
