<Window x:Class="AJTools.UI.ViewCrop.ViewCropTargetViewsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Views"
        Width="900"
        Height="620"
        MinWidth="760"
        MinHeight="480"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="Manual"
        ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../ModernStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <!-- Outer Border for custom rounded window with drop shadow -->
    <Border x:Name="RootBorder"
            Background="{StaticResource BackgroundDark}"
            CornerRadius="8"
            BorderBrush="{StaticResource BorderSoft}"
            BorderThickness="1"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="4" Direction="270" Opacity="0.4" Color="#000000"/>
        </Border.Effect>

        <Grid Margin="16,12,16,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title bar -->
                <RowDefinition Height="Auto"/> <!-- Search row -->
                <RowDefinition Height="Auto"/> <!-- Column headers -->
                <RowDefinition Height="*"/>    <!-- List -->
                <RowDefinition Height="Auto"/> <!-- Selection error -->
                <RowDefinition Height="Auto"/> <!-- Count + buttons -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Grid Grid.Row="0" Margin="0,0,0,12" Background="Transparent" MouseLeftButtonDown="OnTitleBarDrag">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Select target views"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="18"
                               FontWeight="Bold"/>
                    <TextBlock Text="Pick the views to crop. Views that cannot be cropped are listed with a reason and cannot be selected."
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Right">
                    <Button Content="&#xE921;" ToolTip="Minimize" Width="32" Height="32" Margin="0,0,6,0"
                            Style="{StaticResource WindowControlButton}" Click="OnMinimizeClick"/>
                    <Button Content="&#xE922;" ToolTip="Maximize" Width="32" Height="32" Margin="0,0,6,0"
                            Style="{StaticResource WindowControlButton}" Click="OnMaximizeClick"/>
                    <Button Content="&#xE8BB;" ToolTip="Close" Width="32" Height="32"
                            Style="{StaticResource WindowCloseButton}" Click="OnCloseClick"/>
                </StackPanel>
            </Grid>

            <!-- Search + bulk select -->
            <Grid Grid.Row="1" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="SearchTextBox"
                         Grid.Column="0"
                         Style="{StaticResource ModernTextBox}"
                         Margin="0,0,8,0"
                         ToolTip="Search by view name, type, sheet number, or sheet name"
                         TextChanged="OnSearchChanged"/>

                <Button Grid.Column="1"
                        Content="Select All"
                        Style="{StaticResource ModernButton}"
                        MinWidth="110"
                        Margin="0,0,8,0"
                        Click="OnSelectAll"/>

                <Button Grid.Column="2"
                        Content="Clear All"
                        Style="{StaticResource SecondaryButton}"
                        MinWidth="110"
                        Click="OnClearAll"/>
            </Grid>

            <!-- Column headers -->
            <Grid Grid.Row="2" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="46"/>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="1.4*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Pick" Foreground="{StaticResource TextSecondary}" FontWeight="SemiBold"/>
                <TextBlock Grid.Column="1" Text="View Name" Foreground="{StaticResource TextSecondary}" FontWeight="SemiBold"/>
                <TextBlock Grid.Column="2" Text="View Type" Foreground="{StaticResource TextSecondary}" FontWeight="SemiBold"/>
                <TextBlock Grid.Column="3" Text="Sheet No" Foreground="{StaticResource TextSecondary}" FontWeight="SemiBold"/>
                <TextBlock Grid.Column="4" Text="Sheet Name" Foreground="{StaticResource TextSecondary}" FontWeight="SemiBold"/>
            </Grid>

            <ListBox x:Name="ViewsListBox"
                     Grid.Row="3"
                     Style="{StaticResource ModernListBox}"
                     ItemContainerStyle="{StaticResource ModernListBoxItem}"
                     BorderBrush="{StaticResource BorderSoft}"
                     BorderThickness="1"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.CanContentScroll="False">
                <!-- Pixel-scrolling template so the grouped list scrolls smoothly even with many views. -->
                <ListBox.Template>
                    <ControlTemplate TargetType="ListBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ScrollViewer Focusable="False"
                                          Padding="6"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          CanContentScroll="False">
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </ListBox.Template>
                <ListBox.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource BackgroundMedium}" Padding="8" Margin="0,10,0,0" CornerRadius="4">
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="{StaticResource TextPrimary}"
                                               FontWeight="Bold"/>
                                </Border>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ListBox.GroupStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,1,0,1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="46"/>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="1.4*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>

                            <CheckBox Grid.Column="0"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"/>

                            <TextBlock Grid.Column="1"
                                       Text="{Binding ViewName}"
                                       Foreground="{StaticResource TextPrimary}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="4,0"/>

                            <TextBlock Grid.Column="2"
                                       Text="{Binding ViewTypeName}"
                                       Foreground="{StaticResource TextPrimary}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="4,0"/>

                            <TextBlock Grid.Column="3"
                                       Text="{Binding SheetNumber}"
                                       Foreground="{StaticResource TextPrimary}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="4,0"/>

                            <TextBlock Grid.Column="4"
                                       Text="{Binding SheetName}"
                                       Foreground="{StaticResource TextPrimary}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="4,0"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <TextBlock x:Name="SelectionErrorText"
                       Grid.Row="4"
                       Foreground="{StaticResource AccentDanger}"
                       Margin="2,8,0,0"/>

            <Grid Grid.Row="5" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="SelectionCountText"
                           Grid.Column="0"
                           Foreground="{StaticResource TextSecondary}"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Content="Run"
                        Style="{StaticResource ModernButton}"
                        IsDefault="True"
                        MinWidth="110"
                        Margin="0,0,8,0"
                        Click="OnRun"/>

                <Button Grid.Column="2"
                        Content="Cancel"
                        Style="{StaticResource SecondaryButton}"
                        IsCancel="True"
                        MinWidth="110"
                        Click="OnCancel"/>
            </Grid>

            <!-- Footer -->
            <TextBlock Grid.Row="6"
                       Text="Created &amp; All Rights Reserved @ Ajmal P.S."
                       Foreground="{StaticResource TextDisabled}"
                       FontSize="11"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,0"/>
        </Grid>
    </Border>
</Window>
