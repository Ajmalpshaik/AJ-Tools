<Window x:Class="AJTools.UI.ViewCrop.ViewCropAnnotationOptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Annotation Crop Settings"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        ResizeMode="CanResize"
        MinWidth="460">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../ModernStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <!-- Outer Border for custom rounded window with drop shadow -->
    <Border x:Name="RootBorder"
            Background="{StaticResource BackgroundDark}"
            CornerRadius="8"
            BorderBrush="{StaticResource BorderSoft}"
            BorderThickness="1"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="4" Direction="270" Opacity="0.4" Color="#000000"/>
        </Border.Effect>

        <Grid Margin="16,12,16,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title bar -->
                <RowDefinition Height="Auto"/> <!-- Run scope -->
                <RowDefinition Height="Auto"/> <!-- Settings -->
                <RowDefinition Height="Auto"/> <!-- Error -->
                <RowDefinition Height="Auto"/> <!-- Buttons -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Grid Grid.Row="0" Margin="0,0,0,12" Background="Transparent" MouseLeftButtonDown="OnTitleBarDrag">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Annotation Crop Settings"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="18"
                               FontWeight="Bold"/>
                    <TextBlock Text="Turn on the annotation crop and offset it outward from the existing view crop boundary."
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Right">
                    <Button Content="&#xE921;" ToolTip="Minimize" Width="32" Height="32" Margin="0,0,6,0"
                            Style="{StaticResource WindowControlButton}" Click="OnMinimizeClick"/>
                    <Button Content="&#xE922;" ToolTip="Maximize" Width="32" Height="32" Margin="0,0,6,0"
                            Style="{StaticResource WindowControlButton}" Click="OnMaximizeClick"/>
                    <Button Content="&#xE8BB;" ToolTip="Close" Width="32" Height="32"
                            Style="{StaticResource WindowCloseButton}" Click="OnCloseClick"/>
                </StackPanel>
            </Grid>

            <!-- Run Scope -->
            <Border Grid.Row="1" Style="{StaticResource PanelCard}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Run Scope"
                               Foreground="{StaticResource TextPrimary}"
                               FontWeight="Bold"
                               FontSize="13"
                               Margin="0,0,0,8"/>

                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="ActiveViewOnlyRadio"
                                     Content="Active view only"
                                     IsChecked="True"
                                     Style="{StaticResource ModernRadioButton}"
                                     Margin="0,0,24,0"
                                     Checked="OnApplyScopeChanged"
                                     Unchecked="OnApplyScopeChanged"/>
                        <RadioButton x:Name="MultipleViewsRadio"
                                     Content="Choose multiple views"
                                     Style="{StaticResource ModernRadioButton}"
                                     Checked="OnApplyScopeChanged"
                                     Unchecked="OnApplyScopeChanged"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Settings -->
            <Border Grid.Row="2" Style="{StaticResource PanelCard}" Margin="0,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                               Text="Settings"
                               Foreground="{StaticResource TextPrimary}"
                               FontWeight="Bold"
                               FontSize="13"
                               Margin="0,0,0,8"/>

                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="Annotation crop offset (mm):"
                               Foreground="{StaticResource TextPrimary}"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"/>

                    <TextBox x:Name="OffsetTextBox"
                             Grid.Row="1" Grid.Column="1"
                             Style="{StaticResource ModernTextBox}"
                             MinWidth="160"/>
                </Grid>
            </Border>

            <TextBlock x:Name="ErrorText"
                       Grid.Row="3"
                       Foreground="{StaticResource AccentDanger}"
                       Margin="4,8,0,0"
                       TextWrapping="Wrap"
                       Visibility="Collapsed"/>

            <Grid Grid.Row="4" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="RunButton"
                        Grid.Column="1"
                        Content="Run"
                        Style="{StaticResource ModernButton}"
                        IsDefault="True"
                        MinWidth="110"
                        Margin="0,0,12,0"
                        Click="OnRun"/>

                <Button Grid.Column="2"
                        Content="Cancel"
                        Style="{StaticResource SecondaryButton}"
                        IsCancel="True"
                        MinWidth="110"
                        Click="OnCancel"/>
            </Grid>

            <!-- Footer -->
            <TextBlock Grid.Row="5"
                       Text="Created &amp; All Rights Reserved @ Ajmal P.S."
                       Foreground="{StaticResource TextDisabled}"
                       FontSize="11"
                       HorizontalAlignment="Center"
                       Margin="0,12,0,0"/>
        </Grid>
    </Border>
</Window>
