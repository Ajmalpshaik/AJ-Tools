<Window x:Class="AJTools.UI.ViewCrop.ViewCropOptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="View Crop Settings"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        ResizeMode="CanResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../ModernStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <!-- Outer Border for custom rounded window with drop shadow -->
    <Border x:Name="RootBorder"
            Background="{StaticResource BackgroundDark}"
            CornerRadius="8"
            BorderBrush="{StaticResource BorderSoft}"
            BorderThickness="1"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="4" Direction="270" Opacity="0.4" Color="#000000"/>
        </Border.Effect>

        <!-- Main Layout -->
        <Grid Margin="16,12,16,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Row 0: Header / Title Bar -->
                <RowDefinition Height="Auto"/> <!-- Row 1: Card 0 - Crop Mode -->
                <RowDefinition Height="Auto"/> <!-- Row 2: Card 1 - Run Scope -->
                <RowDefinition Height="Auto"/> <!-- Row 3: Card 2 - View Crop Options -->
                <RowDefinition Height="Auto"/> <!-- Row 4: Card 3 - Annotation Crop -->
                <RowDefinition Height="Auto"/> <!-- Row 5: Error Text -->
                <RowDefinition Height="Auto"/> <!-- Row 6: Buttons -->
                <RowDefinition Height="Auto"/> <!-- Row 7: Footer -->
            </Grid.RowDefinitions>

            <!-- Custom Header / Title Area -->
            <Grid Grid.Row="0" Margin="0,0,0,12" Background="Transparent" MouseLeftButtonDown="OnTitleBarDrag">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="View Crop Settings"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="18"
                               FontWeight="Bold"/>
                    <TextBlock Text="Fit the crop region tightly around the model."
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"/>
                </StackPanel>
                
                <!-- Window Controls (Minimize, Maximize, Close) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,0,0,0">
                    <Button Content="&#xE921;" 
                            ToolTip="Minimize"
                            Width="32" Height="32"
                            Margin="0,0,6,0"
                            Style="{StaticResource WindowControlButton}"
                            Click="OnMinimizeClick"/>
                    <Button Content="&#xE922;" 
                            ToolTip="Maximize"
                            Width="32" Height="32"
                            Margin="0,0,6,0"
                            Style="{StaticResource WindowControlButton}"
                            Click="OnMaximizeClick"/>
                    <Button Content="&#xE8BB;" 
                            ToolTip="Close"
                            Width="32" Height="32"
                            Style="{StaticResource WindowCloseButton}"
                            Click="OnCloseClick"/>
                </StackPanel>
            </Grid>

            <!-- Card 0: Crop Mode -->
            <ContentControl Grid.Row="1" Style="{StaticResource PanelCard}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Crop Mode"
                               Foreground="{StaticResource TextPrimary}"
                               FontWeight="Bold"
                               FontSize="13"
                               Margin="0,0,0,8"/>

                    <RadioButton x:Name="ModeAllModelRadio"
                                 Content="All model elements"
                                 IsChecked="True"
                                 Style="{StaticResource ModernRadioButton}"
                                 Margin="0,0,0,2"/>
                    <TextBlock Text="Fits each view around the full project footprint, regardless of view settings."
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="11"
                               Margin="24,0,0,8"/>

                    <RadioButton x:Name="ModeVisibleRadio"
                                 Content="Visible elements in each view"
                                 Style="{StaticResource ModernRadioButton}"
                                 Margin="0,0,0,2"/>
                    <TextBlock Text="Fits each view around only what is currently visible in that view."
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="11"
                               Margin="24,0,0,0"/>
                </StackPanel>
            </ContentControl>

            <!-- Card 1: Run Scope -->
            <ContentControl Grid.Row="2" Style="{StaticResource PanelCard}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Run Scope"
                               Foreground="{StaticResource TextPrimary}"
                               FontWeight="Bold"
                               FontSize="13"
                               Margin="0,0,0,8"/>

                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="ActiveViewOnlyRadio"
                                     Content="Active view only"
                                     IsChecked="True"
                                     Style="{StaticResource ModernRadioButton}"
                                     Margin="0,0,24,0"
                                     Checked="OnApplyScopeChanged"
                                     Unchecked="OnApplyScopeChanged"/>
                        <RadioButton x:Name="MultipleViewsRadio"
                                     Content="Choose multiple views"
                                     Style="{StaticResource ModernRadioButton}"
                                     Checked="OnApplyScopeChanged"
                                     Unchecked="OnApplyScopeChanged"/>
                    </StackPanel>
                </StackPanel>
            </ContentControl>

            <!-- Card 2: View Crop Settings -->
            <ContentControl Grid.Row="3" Style="{StaticResource PanelCard}" Margin="0,0,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                               Text="View Crop Options"
                               Foreground="{StaticResource TextPrimary}"
                               FontWeight="Bold"
                               FontSize="13"
                               Margin="0,0,0,8"/>

                    <!-- Margin Preset -->
                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="Margin Preset:"
                               Foreground="{StaticResource TextPrimary}"
                               VerticalAlignment="Center"
                               Margin="0,0,12,10"/>

                    <ComboBox x:Name="PresetComboBox"
                              Grid.Row="1"
                              Grid.Column="1"
                              Margin="0,0,0,10"
                              SelectionChanged="OnPresetChanged"/>

                    <!-- Custom Margin -->
                    <TextBlock Grid.Row="2" Grid.Column="0"
                               Text="Margin size (mm):"
                               Foreground="{StaticResource TextPrimary}"
                               VerticalAlignment="Center"
                               Margin="0,0,12,12"/>

                    <TextBox x:Name="MarginTextBox"
                             Grid.Row="2"
                             Grid.Column="1"
                             Style="{StaticResource ModernTextBox}"
                             Margin="0,0,0,12"
                             MinWidth="140"
                             TextChanged="OnMarginTextChanged"/>

                    <!-- 1. Include Revit links checkbox & subtitle -->
                    <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Margin="0,0,0,10">
                        <CheckBox x:Name="IncludeLinksCheckBox"
                                  Content="Include Revit links"
                                  Style="{StaticResource ModernCheckBox}"/>
                        <TextBlock Text="Fits crop tightly around elements inside linked models (highly accurate)"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="11"
                                   Margin="24,2,0,0"/>
                    </StackPanel>

                    <!-- 2. Include coordination models checkbox & subtitle -->
                    <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Margin="0,0,0,10">
                        <CheckBox x:Name="IncludeCoordinationModelsCheckBox"
                                  Content="Include coordination models"
                                  Style="{StaticResource ModernCheckBox}"/>
                        <TextBlock Text="Includes Navisworks coordination models in the active project (ignores linked ones)"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="11"
                                   Margin="24,2,0,0"/>
                    </StackPanel>

                    <!-- 3. Include datums checkbox & subtitle -->
                    <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Margin="0,0,0,10">
                        <CheckBox x:Name="IncludeDatumsCheckBox"
                                  Content="Include datums"
                                  Style="{StaticResource ModernCheckBox}"/>
                        <TextBlock Text="Includes level lines, grid lines, and reference planes in the crop calculations"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="11"
                                   Margin="24,2,0,0"/>
                    </StackPanel>

                    <!-- 4. Respect hidden categories checkbox & subtitle -->
                    <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Margin="0,0,0,4">
                        <CheckBox x:Name="IgnoreHiddenCheckBox"
                                  Content="Respect hidden categories"
                                  Style="{StaticResource ModernCheckBox}"/>
                        <TextBlock Text="Ignores model elements whose categories are hidden in your view"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="11"
                                   Margin="24,2,0,0"/>
                    </StackPanel>
                </Grid>
            </ContentControl>

            <!-- Card 3: Unified Annotation Crop Settings -->
            <ContentControl Grid.Row="4" Style="{StaticResource PanelCard}" Margin="0,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                               Text="Annotation Crop Integration (Optional)"
                               Foreground="{StaticResource TextPrimary}"
                               FontWeight="Bold"
                               FontSize="13"
                               Margin="0,0,0,8"/>

                    <!-- Toggle integrated annotation crop -->
                    <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,0,0,12">
                        <CheckBox x:Name="ApplyAnnotationCheckBox"
                                  Content="Enable annotation crop automatically"
                                  Style="{StaticResource ModernCheckBox}"
                                  Checked="OnApplyAnnotationToggled"
                                  Unchecked="OnApplyAnnotationToggled"/>
                        <TextBlock Text="Triggers the annotation crop tool in a single click after cropping"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="11"
                                   Margin="24,2,0,0"/>
                    </StackPanel>

                    <!-- Annotation offset -->
                    <TextBlock x:Name="AnnotationOffsetLabel"
                               Grid.Row="2" Grid.Column="0"
                               Text="Annotation offset (mm):"
                               Foreground="{StaticResource TextPrimary}"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"
                               IsEnabled="False"/>

                    <TextBox x:Name="AnnotationOffsetTextBox"
                             Grid.Row="2"
                             Grid.Column="1"
                             Style="{StaticResource ModernTextBox}"
                             Text="100"
                             MinWidth="140"
                             IsEnabled="False"/>
                </Grid>
            </ContentControl>

            <TextBlock x:Name="ErrorText"
                       Grid.Row="5"
                       Foreground="{StaticResource AccentDanger}"
                       Margin="4,0,0,0"
                       Visibility="Collapsed"/>

            <Grid Grid.Row="6" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="DiagnosticsButton"
                        Grid.Column="0"
                        Content="Boundary Diagnostics"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,0,0"
                        Click="OnDiagnosticsRun"/>

                <Button x:Name="RunButton"
                        Grid.Column="2"
                        Content="Run"
                        Style="{StaticResource ModernButton}"
                        IsDefault="True"
                        Margin="0,0,12,0"
                        Click="OnRun"/>

                <Button Grid.Column="3"
                        Content="Cancel"
                        Style="{StaticResource SecondaryButton}"
                        IsCancel="True"
                        Click="OnCancel"/>
            </Grid>

            <!-- Footer -->
            <TextBlock Grid.Row="7"
                       Text="Created &amp; All Rights Reserved @ Ajmal P.S."
                       Foreground="{StaticResource TextDisabled}"
                       FontSize="11"
                       HorizontalAlignment="Center"
                       Margin="0,12,0,0"/>
        </Grid>
    </Border>
</Window>
