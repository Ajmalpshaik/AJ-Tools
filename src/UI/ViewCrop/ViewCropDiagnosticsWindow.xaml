<Window x:Class="AJTools.UI.ViewCrop.ViewCropDiagnosticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AJ Tools - View Crop Boundary Diagnostics"
        Width="540"
        Height="620"
        MinWidth="450"
        MinHeight="500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="Manual"
        ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../ModernStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <!-- Outer Border for custom rounded window with drop shadow -->
    <Border x:Name="RootBorder"
            Background="{StaticResource BackgroundDark}"
            CornerRadius="8"
            BorderBrush="{StaticResource BorderSoft}"
            BorderThickness="1"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="4" Direction="270" Opacity="0.4" Color="#000000"/>
        </Border.Effect>

        <Grid Margin="16,12,16,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title bar -->
                <RowDefinition Height="Auto"/> <!-- Description -->
                <RowDefinition Height="*"/>    <!-- Report text -->
                <RowDefinition Height="Auto"/> <!-- Notification -->
                <RowDefinition Height="Auto"/> <!-- Buttons -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Grid Grid.Row="0" Margin="0,0,0,12" Background="Transparent" MouseLeftButtonDown="OnTitleBarDrag">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Crop Boundary Diagnostics"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="18"
                               FontWeight="Bold"/>
                    <TextBlock Text="The outermost elements that define each view's crop boundary."
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Right">
                    <Button Content="&#xE921;" ToolTip="Minimize" Width="32" Height="32" Margin="0,0,6,0"
                            Style="{StaticResource WindowControlButton}" Click="OnMinimizeClick"/>
                    <Button Content="&#xE922;" ToolTip="Maximize" Width="32" Height="32" Margin="0,0,6,0"
                            Style="{StaticResource WindowControlButton}" Click="OnMaximizeClick"/>
                    <Button Content="&#xE8BB;" ToolTip="Close" Width="32" Height="32"
                            Style="{StaticResource WindowCloseButton}" Click="OnCloseClick"/>
                </StackPanel>
            </Grid>

            <!-- Hint -->
            <TextBlock Grid.Row="1"
                       Text="Copy this log and share it to diagnose stray, huge, or far-away elements pushing the crop out."
                       Foreground="{StaticResource TextSecondary}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,0,0,10"/>

            <!-- Report text -->
            <Border Grid.Row="2"
                    Background="{StaticResource CardBackground}"
                    CornerRadius="14"
                    Padding="8"
                    Margin="0,0,0,10">
                <TextBox x:Name="DiagnosticsTextBox"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         Background="Transparent"
                         Foreground="{StaticResource TextPrimary}"
                         BorderThickness="0"
                         FontFamily="Consolas"
                         FontSize="11.5"
                         Padding="4"/>
            </Border>

            <!-- Copy confirmation -->
            <TextBlock x:Name="NotificationText"
                       Grid.Row="3"
                       Foreground="{StaticResource TextSuccess}"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"
                       Visibility="Collapsed"/>

            <!-- Action Buttons -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1"
                        Content="Copy Report"
                        Style="{StaticResource ModernButton}"
                        MinWidth="160"
                        Margin="0,0,8,0"
                        Click="OnCopyReport"/>

                <Button Grid.Column="2"
                        Content="Close"
                        Style="{StaticResource SecondaryButton}"
                        IsCancel="True"
                        MinWidth="100"
                        Click="OnClose"/>
            </Grid>

            <!-- Footer -->
            <TextBlock Grid.Row="5"
                       Text="Created &amp; All Rights Reserved @ Ajmal P.S."
                       Foreground="{StaticResource TextDisabled}"
                       FontSize="11"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,0"/>
        </Grid>
    </Border>
</Window>
