<!--
  Tool Name: Duct Flow Annotations - Settings
  Description: Dialog for selecting the annotation family and spacing.
  Author: Ajmal P.S.
  Version: 1.0.0
  Last Updated: 2025-12-21
  Revit Version: 2020
  Dependencies: Autodesk.Revit.DB, Autodesk.Revit.UI
-->
<Window x:Class="AJTools.UI.FlowDirectionSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Duct Flow Settings"
        Width="500"
        Height="390"
        MinWidth="420"
        MinHeight="320"
        ResizeMode="CanResize"
        SizeToContent="Manual"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundDark}"
        Foreground="{DynamicResource TextPrimary}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ModernStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="8">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Border Background="{StaticResource CardBackground}"
                    BorderBrush="{StaticResource BorderSoft}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Duct Flow Settings"
                           FontWeight="Bold"
                           FontSize="14"
                           Foreground="{StaticResource TextPrimary}"
                           Grid.Row="0"
                           Margin="0,0,0,8"/>

                <StackPanel Grid.Row="1" Margin="0,0,0,8">
                    <TextBlock Text="Annotation Family"
                               FontWeight="SemiBold"
                               FontSize="12"
                               Foreground="{StaticResource TextPrimary}"
                               Margin="0,0,0,4"/>
                    <ComboBox x:Name="FamilyCombo"
                              Height="34"
                              HorizontalAlignment="Stretch"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="0,0,0,8">
                    <TextBlock Text="Spacing"
                               FontWeight="SemiBold"
                               FontSize="12"
                               Foreground="{StaticResource TextPrimary}"
                               Margin="0,0,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="SpacingBox"
                                 Grid.Column="0"
                                 Style="{StaticResource ModernTextBox}"/>
                        <TextBlock x:Name="SpacingUnitText"
                                   Grid.Column="1"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondary}"/>
                    </Grid>
                </StackPanel>

                <TextBlock x:Name="ErrorText"
                           Grid.Row="3"
                           Foreground="{StaticResource AccentDanger}"
                           Margin="0,0,0,8"/>

                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="1"
                            Content="Start"
                            Style="{StaticResource ModernButton}"
                            Click="OnStart"
                            IsDefault="True"
                            MinWidth="110"
                            Margin="0,0,8,0"/>
                    <Button Grid.Column="2"
                            Content="Cancel"
                            Style="{StaticResource SecondaryButton}"
                            Click="OnCancel"
                            IsCancel="True"
                            MinWidth="110"/>
                </Grid>
            </Grid>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>

